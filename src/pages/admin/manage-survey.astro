---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { supabase } from "../../lib/supabase.js";

// NARIK DATA DARI SUPABASE
// Kita sekalian ambil jumlah 'responses' biar tau udah berapa orang yang ngisi
const { data: surveys, error } = await supabase
  .from("surveys")
  .select("*, responses(count)")
  .order("created_at", { ascending: false });
---
<BaseLayout title="Kelola Kuesioner | Admin CDC">
  <div class="admin-container" id="adminWrapper" style="display: none;">
    <header class="admin-header">
      <div>
        <span class="eyebrow">Admin Dashboard</span>
        <h1>Kelola Kuesioner</h1>
        <p>Pantau dan kelola semua kuesioner CDC STT-NF.</p>
      </div>
      <a
        href="/admin/builder"
        class="btn-primary"
        style="text-decoration: none;"
      >
        + Buat Survey Baru
      </a>
    </header>

    <div class="table-container card">
      <table>
        <thead>
          <tr>
            <th>Nama Kuesioner</th>
            <th>Tipe Form</th>
            <th>Responden</th>
            <th>Status</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          {
            surveys && surveys.length > 0 ? (
              surveys.map((survey) => (
                <tr id={`row-${survey.id}`}>
                  <td>
                    <div class="survey-info">
                      <strong>{survey.title}</strong>
                      <span>
                        Dibuat:{" "}
                        {new Date(survey.created_at).toLocaleDateString(
                          "id-ID",
                        )}
                      </span>
                    </div>
                  </td>
                  <td>
                    <span class="tag">Kuesioner</span>
                  </td>
                  <td>
                    <span style="font-weight: 700; color: #0f172a; font-size: 15px;">
                      {survey.responses[0]?.count || 0}
                    </span>
                    <span style="color: #64748b; font-size: 13px; margin-left: 4px;">
                      orang
                    </span>
                  </td>
                  <td>
                    <button
                      class={`status-toggle ${survey.is_active ? "active" : "draft"}`}
                      data-id={survey.id}
                      data-status={survey.is_active ? "true" : "false"}
                      title="Klik untuk mengubah status (Buka/Tutup)"
                    >
                      <span class="dot" />
                      <span class="status-text">
                        {survey.is_active ? "Dibuka" : "Ditutup"}
                      </span>
                    </button>
                  </td>
                  <td class="actions">
                    <button
                      class="btn-icon copy-btn"
                      data-id={survey.id}
                      title="Salin Link"
                    >
                      <svg
                        width="16"
                        height="16"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"
                        />
                      </svg>
                    </button>
                    <a
                      href={`/admin/edit/${survey.id}`}
                      class="btn-icon"
                      title="Edit"
                    >
                      <svg
                        width="16"
                        height="16"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
                        />
                      </svg>
                    </a>
                    <a
                      href={`/admin/hasil/${survey.id}`}
                      class="btn-icon"
                      title="Lihat Hasil Excel"
                    >
                      <svg
                        width="16"
                        height="16"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                        />
                      </svg>
                    </a>
                    <button
                      class="btn-icon danger delete-btn"
                      data-id={survey.id}
                      title="Hapus Kuesioner"
                    >
                      <svg
                        width="16"
                        height="16"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                        />
                      </svg>
                    </button>
                  </td>
                </tr>
              ))
            ) : (
              <tr>
                <td
                  colspan="5"
                  style="text-align: center; padding: 60px 20px; color: #64748b;"
                >
                  <div style="font-size: 40px; margin-bottom: 16px;">📋</div>
                  <p style="font-size: 16px; font-weight: 600;">
                    Belum ada kuesioner
                  </p>
                  <p style="font-size: 14px; margin-top: 4px;">
                    Klik tombol "Buat Survey Baru" untuk memulai.
                  </p>
                </td>
              </tr>
            )
          }
        </tbody>
      </table>
    </div>
  </div>

  <style>
    .admin-container {
      padding: 40px 0;
      max-width: 1000px;
      margin: 0 auto;
      font-family: system-ui, sans-serif;
    }
    .admin-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 32px;
      border-bottom: 1px solid #e2e8f0;
      padding-bottom: 24px;
    }
    .eyebrow {
      font-size: 12px;
      font-weight: 800;
      color: #4f46e5;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }
    .admin-header h1 {
      font-size: 32px;
      margin-top: 8px;
      color: #0f172a;
      font-weight: 800;
      letter-spacing: -0.02em;
    }
    .admin-header p {
      color: #64748b;
      margin-top: 8px;
      font-size: 15px;
    }
    .card {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 20px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.02);
      overflow: hidden;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }
    th {
      background: #f8fafc;
      text-align: left;
      padding: 16px 24px;
      font-size: 13px;
      color: #475569;
      font-weight: 700;
      border-bottom: 2px solid #e2e8f0;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    td {
      padding: 20px 24px;
      border-bottom: 1px solid #f1f5f9;
      font-size: 14px;
      vertical-align: middle;
    }
    tr:hover {
      background-color: #fafaf9;
    }

    .survey-info strong {
      display: block;
      color: #0f172a;
      font-size: 15px;
      margin-bottom: 4px;
    }
    .survey-info span {
      font-size: 12px;
      color: #64748b;
    }
    .tag {
      background: #f1f5f9;
      color: #475569;
      padding: 4px 10px;
      border-radius: 6px;
      font-size: 12px;
      font-weight: 700;
    }

    /* TOMBOL STATUS (BUKA/TUTUP) */
    .status-toggle {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: 99px;
      font-size: 12px;
      font-weight: 700;
      border: none;
      cursor: pointer;
      transition: 0.2s;
    }
    .status-toggle .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
    }
    .status-toggle.active {
      background: #dcfce7;
      color: #166534;
    }
    .status-toggle.active .dot {
      background: #22c55e;
    }
    .status-toggle.draft {
      background: #f1f5f9;
      color: #475569;
    }
    .status-toggle.draft .dot {
      background: #94a3b8;
    }
    .status-toggle:hover {
      transform: scale(1.05);
    }

    .actions {
      display: flex;
      gap: 8px;
    }
    .btn-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      cursor: pointer;
      color: #475569;
      transition: 0.2s;
    }
    .btn-icon:hover {
      background: #f8fafc;
      color: #0f172a;
      border-color: #cbd5e1;
      transform: translateY(-2px);
    }
    .btn-icon.danger:hover {
      background: #fef2f2;
      color: #ef4444;
      border-color: #fca5a5;
    }

    .btn-primary {
      background: #0f172a;
      color: white;
      border: none;
      padding: 12px 24px;
      border-radius: 12px;
      font-weight: 700;
      font-size: 14px;
      cursor: pointer;
      transition: 0.2s;
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(15, 23, 42, 0.15);
      background: #4f46e5;
    }
    /* =========================================
       RESPONSIVE DESIGN (HP & TABLET)
       ========================================= */
    @media (max-width: 768px) {
      /* Header sama tombol buat survey dibikin numpuk atas bawah */
      .page-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
      }
      
      .page-title {
        font-size: 24px;
      }

      /* Tabel dikasih scroll ke samping biar nggak nabrak layar */
      .table-wrapper {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      /* Tombol aksi (Edit, Salin, dll) dibikin lebih rapet */
      .action-buttons {
        gap: 4px;
      }
      .btn-action {
        padding: 6px;
      }
    }
  </style>

  <script>
    // @ts-nocheck
    import { supabase } from "../../lib/supabase.js";

    // PROTEKSI HALAMAN (Hanya Admin yang bisa masuk)
    // PROTEKSI HALAMAN (Cek Role dari Database Kelola Pengguna)
    // PROTEKSI HALAMAN
    async function checkAdmin() {
      const { data: authData } = await supabase.auth.getUser();

      if (!authData?.user) {
        alert("Akses Ditolak! Silakan login terlebih dahulu.");
        window.location.href = "/login";
        return;
      }

      const userEmail = authData.user.email;

      // Ambil role dari Supabase
      const { data: userData, error: dbError } = await supabase
        .from("profiles") // Pastikan nama tabelnya beneran 'profiles'
        .select("role")
        .eq("email", userEmail)
        .maybeSingle();

      // BERSIHIN TEKS: Ubah jadi huruf kecil semua dan hapus spasi nyangkut
      const role = userData?.role?.toLowerCase().trim() || "";

      // Kunci darurat
      const isAbsoluteSuperAdmin =
        userEmail === "email_superadmin_lo@gmail.com";

      const isAllowed =
        role === "superadmin" || role === "admin" || role === "dosen";

      // // --- BAGIAN DETEKTIF ---
      // // Buka Inspect Element (F12) > Console buat liat ini pas lo login error
      // console.log("Email yang login:", userEmail);
      // console.log("Data dari database:", userData);
      // console.log("Error dari database:", dbError);
      // // -----------------------

      if (isAllowed || isAbsoluteSuperAdmin) {
        document.getElementById("adminWrapper").style.display = "block";
      } else {
        alert(
          `Akses Ditolak! Email ${userEmail} terbaca sebagai role: "${role}"`,
        );
        window.location.href = "/";
      }
    }

    checkAdmin();

    // 1. FITUR HAPUS KUESIONER
    document.querySelectorAll(".delete-btn").forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        const btnEl = e.currentTarget;
        const surveyId = btnEl.getAttribute("data-id");

        const isConfirm = confirm(
          "Yakin mau hapus permanen kuesioner ini beserta seluruh datanya?",
        );
        if (isConfirm) {
          btnEl.style.opacity = "0.5";
          const { error } = await supabase
            .from("surveys")
            .delete()
            .eq("id", surveyId);
          if (error) {
            alert("Gagal menghapus kuesioner.");
            btnEl.style.opacity = "1";
          } else {
            document.getElementById(`row-${surveyId}`).remove();
          }
        }
      });
    });

    // 2. FITUR SALIN LINK MAHASISWA
    document.querySelectorAll(".copy-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const btnEl = e.currentTarget;
        const surveyId = btnEl.getAttribute("data-id");
        const link = `${window.location.origin}/kuesioner/${surveyId}`;

        navigator.clipboard.writeText(link).then(() => {
          btnEl.style.background = "#dcfce7";
          btnEl.style.color = "#166534";
          btnEl.style.borderColor = "#bbf7d0";
          setTimeout(() => {
            btnEl.style.background = "";
            btnEl.style.color = "";
            btnEl.style.borderColor = "";
          }, 2000);
        });
      });
    });

    // 3. FITUR TUTUP/BUKA KUESIONER (Toggle Status)
    document.querySelectorAll(".status-toggle").forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        const btnEl = e.currentTarget;
        const surveyId = btnEl.getAttribute("data-id");
        const currentStatus = btnEl.getAttribute("data-status") === "true";
        const newStatus = !currentStatus; // Balik statusnya

        btnEl.style.opacity = "0.5";

        const { error } = await supabase
          .from("surveys")
          .update({ is_active: newStatus })
          .eq("id", surveyId);

        if (error) {
          alert("Gagal merubah status.");
        } else {
          // Update tampilan tombol secara real-time
          btnEl.setAttribute("data-status", newStatus.toString());
          if (newStatus) {
            btnEl.className = "status-toggle active";
            btnEl.querySelector(".status-text").textContent = "Dibuka";
          } else {
            btnEl.className = "status-toggle draft";
            btnEl.querySelector(".status-text").textContent = "Ditutup";
          }
        }
        btnEl.style.opacity = "1";
      });
    });
  </script>
</BaseLayout>
