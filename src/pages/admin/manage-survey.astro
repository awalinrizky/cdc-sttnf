---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { supabase } from "../../lib/supabase.js";

// NARIK DATA DARI SUPABASE (Astro Server-Side)
const { data: surveys, error } = await supabase
  .from("surveys")
  .select("*")
  .order("created_at", { ascending: false });
---

<BaseLayout title="Manage Surveys | Admin CDC">
  <div class="admin-container">
    <header class="admin-header">
      <div>
        <span class="eyebrow">Admin Dashboard</span>
        <h1>Kelola Kuesioner</h1>
        <p>Pantau dan kelola semua kuesioner CDC STT-NF.</p>
      </div>
      <a
        href="/admin/builder"
        class="btn-primary"
        style="text-decoration: none;">+ Buat Survey Baru</a
      >
    </header>

    <div class="table-container card">
      <table>
        <thead>
          <tr>
            <th>Nama Kuesioner</th>
            <th>Tipe Form</th>
            <th>Status</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          {
            surveys && surveys.length > 0 ? (
              surveys.map((survey) => (
                <tr id={`row-${survey.id}`}>
                  <td>
                    <div class="survey-info">
                      <strong>{survey.title}</strong>
                      <span>
                        Dibuat:{" "}
                        {new Date(survey.created_at).toLocaleDateString(
                          "id-ID",
                        )}
                      </span>
                    </div>
                  </td>
                  <td>
                    <span class="tag">Custom Schema</span>
                  </td>
                  <td>
                    <span
                      class={`status-badge ${survey.is_active ? "active" : "draft"}`}
                    >
                      {survey.is_active ? "Aktif" : "Draft"}
                    </span>
                  </td>
                  <td class="actions">
                    {/* Tambahin tombol Edit ini yang ngarah ke folder edit */}
                    <a
                      href={`/admin/edit/${survey.id}`}
                      class="btn-icon"
                      style="text-decoration: none;"
                    >
                      Edit
                    </a>

                    <button class="btn-icon copy-btn" data-id={survey.id}>
                      Salin Link
                    </button>
                    <a
                      href={`/admin/hasil/${survey.id}`}
                      class="btn-icon"
                      style="text-decoration: none;"
                    >
                      Lihat Hasil
                    </a>
                    <button
                      class="btn-icon danger delete-btn"
                      data-id={survey.id}
                    >
                      Hapus
                    </button>
                  </td>
                </tr>
              ))
            ) : (
              <tr>
                <td
                  colspan="4"
                  style="text-align: center; padding: 40px; color: #64748b;"
                >
                  Belum ada kuesioner. Klik "Buat Survey Baru" untuk mulai.
                </td>
              </tr>
            )
          }
        </tbody>
      </table>
    </div>
  </div>

  <style>
    /* CSS masih sama mewahnya */
    .admin-container {
      padding: 40px 0;
      max-width: 1000px;
      margin: 0 auto;
    }
    .admin-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 40px;
      border-bottom: 1px solid #e2e8f0;
      padding-bottom: 24px;
    }
    .eyebrow {
      font-size: 12px;
      font-weight: 800;
      color: #4f46e5;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }
    .admin-header h1 {
      font-size: 32px;
      margin-top: 8px;
      color: #0f172a;
      font-weight: 800;
    }
    .admin-header p {
      color: #64748b;
      margin-top: 4px;
    }
    .card {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 24px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.02);
    }
    .table-container {
      overflow: hidden;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      background: white;
    }
    th {
      background: #f8fafc;
      text-align: left;
      padding: 16px 24px;
      font-size: 13px;
      color: #64748b;
      font-weight: 700;
      border-bottom: 1px solid #e2e8f0;
    }
    td {
      padding: 20px 24px;
      border-bottom: 1px solid #f1f5f9;
      font-size: 14px;
    }
    .survey-info strong {
      display: block;
      color: #0f172a;
      font-size: 16px;
      margin-bottom: 4px;
    }
    .survey-info span {
      font-size: 13px;
      color: #94a3b8;
    }
    .tag {
      background: #f1f5f9;
      color: #475569;
      padding: 4px 10px;
      border-radius: 6px;
      font-size: 12px;
      font-weight: 700;
    }
    .status-badge {
      padding: 6px 14px;
      border-radius: 99px;
      font-size: 12px;
      font-weight: 700;
    }
    .status-badge.active {
      background: #dcfce7;
      color: #166534;
    }
    .status-badge.draft {
      background: #fee2e2;
      color: #991b1b;
    }
    .actions {
      display: flex;
      gap: 8px;
    }
    .btn-icon {
      background: white;
      border: 1px solid #e2e8f0;
      padding: 8px 16px;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 600;
      font-size: 13px;
      color: #0f172a;
      transition: 0.2s;
    }
    .btn-icon:hover {
      background: #f8fafc;
      border-color: #cbd5e1;
    }
    .btn-icon.danger {
      color: #ef4444;
      border-color: #fee2e2;
      background: #fff5f5;
    }
    .btn-icon.danger:hover {
      background: #fef2f2;
      border-color: #fca5a5;
    }
    .btn-primary {
      background: #0f172a;
      color: white;
      border: none;
      padding: 12px 24px;
      border-radius: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: 0.2s;
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
      background: #4f46e5;
    }
  </style>

  <script>
    // @ts-nocheck
    import { supabase } from "../../lib/supabase.js";

    // 1. FITUR HAPUS KUESIONER
    const deleteButtons = document.querySelectorAll(".delete-btn");
    deleteButtons.forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        const surveyId = e.target.getAttribute("data-id");

        // Konfirmasi dulu biar gak kepencet gak sengaja
        const isConfirm = confirm(
          "Yakin mau hapus kuesioner ini? Semua jawaban responden bakal ikut kehapus lho.",
        );

        if (isConfirm) {
          e.target.textContent = "Menghapus...";
          e.target.disabled = true;

          const { error } = await supabase
            .from("surveys")
            .delete()
            .eq("id", surveyId);

          if (error) {
            alert("Gagal menghapus kuesioner.");
            console.error(error);
            e.target.textContent = "Hapus";
            e.target.disabled = false;
          } else {
            // Hapus baris tabel dari layar tanpa harus refresh halaman
            document.getElementById(`row-${surveyId}`).remove();
          }
        }
      });
    });

    // 2. FITUR SALIN LINK (Buat di-share ke Alumni)
    const copyButtons = document.querySelectorAll(".copy-btn");
    copyButtons.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const surveyId = e.target.getAttribute("data-id");
        // Bikin URL lengkap sesuai domain saat ini
        const link = `${window.location.origin}/kuesioner/${surveyId}`;

        // Copy ke clipboard
        navigator.clipboard.writeText(link).then(() => {
          const originalText = e.target.textContent;
          e.target.textContent = "Tersalin! ✅";
          e.target.style.color = "#10b981"; // Ganti ijo
          e.target.style.borderColor = "#10b981";

          // Balikin teks ke semula setelah 2 detik
          setTimeout(() => {
            e.target.textContent = originalText;
            e.target.style.color = "";
            e.target.style.borderColor = "";
          }, 2000);
        });
      });
    });
  </script>
</BaseLayout>
