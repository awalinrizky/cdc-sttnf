---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="CDC STT-NF | Kelola Blog">
  <section class="admin-page">
    <div class="container">
      <div class="page-header">
        <div>
          <span class="eyebrow">Admin Panel</span>
          <h1>Kelola Artikel Blog</h1>
          <p class="subtext">
            Tambah, edit, hapus, dan atur artikel karier yang tampil di halaman blog.
          </p>
        </div>

        <div class="header-actions">
          <a href="/admin" class="btn btn-outline">Kembali ke Dashboard</a>
          <button id="logoutBtn" class="btn btn-danger">Logout</button>
        </div>
      </div>

      <div class="admin-layout">
        <aside class="form-card">
          <div class="card-head">
            <h2 id="formTitle">Tambah Artikel</h2>
            <p>Tulis artikel singkat, jelas, dan gunakan slug yang unik.</p>
          </div>

          <form id="postForm" class="admin-form">
            <div class="form-group">
              <label for="title">Judul Artikel</label>
              <input type="text" id="title" required />
            </div>

            <div class="form-group">
              <label for="slug">Slug</label>
              <input type="text" id="slug" placeholder="tips-membuat-cv-ats" required />
            </div>

            <div class="form-group">
              <label for="content">Isi Artikel</label>
              <textarea id="content" rows="10"></textarea>
            </div>

            <div class="checkbox-group">
              <input type="checkbox" id="published" checked />
              <label for="published">Publikasikan</label>
            </div>

            <div class="form-actions">
              <button type="submit" id="submitBtn" class="btn btn-primary">Simpan Artikel</button>
              <button type="button" id="cancelEditBtn" class="btn btn-outline" hidden>Batal Edit</button>
            </div>

            <p id="formMessage" class="message"></p>
          </form>
        </aside>

        <section class="list-card">
          <div class="list-head">
            <div>
              <h2>Daftar Artikel</h2>
              <p>Kelola semua artikel blog CDC STT-NF dari panel ini.</p>
            </div>

            <input
              type="text"
              id="searchInput"
              placeholder="Cari judul / slug..."
            />
          </div>

          <div id="postList" class="item-list">
            <p class="empty">Memuat artikel...</p>
          </div>
        </section>
      </div>
    </div>
  </section>

  <style>
    .container {
      width: min(100% - 32px, 1200px);
      margin-inline: auto;
    }

    .admin-page {
      padding: 48px 0 72px;
    }

    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
      flex-wrap: wrap;
      margin-bottom: 28px;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      padding: 8px 12px;
      border-radius: 999px;
      background: #dcfce7;
      color: #166534;
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 16px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    h1 {
      font-size: clamp(32px, 4vw, 48px);
      letter-spacing: -0.03em;
      margin-bottom: 10px;
      color: #0f172a;
      line-height: 1.05;
    }

    .subtext {
      max-width: 760px;
      color: #64748b;
      line-height: 1.8;
      font-size: 16px;
    }

    .header-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .admin-layout {
      display: grid;
      grid-template-columns: 400px 1fr;
      gap: 24px;
      align-items: start;
    }

    .form-card,
    .list-card {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 22px;
      padding: 24px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
    }

    .form-card {
      position: sticky;
      top: 100px;
    }

    .card-head,
    .list-head {
      margin-bottom: 18px;
    }

    .card-head h2,
    .list-head h2 {
      font-size: 26px;
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin-bottom: 8px;
      color: #0f172a;
    }

    .card-head p,
    .list-head p {
      color: #64748b;
      line-height: 1.8;
      font-size: 14px;
    }

    .admin-form {
      display: grid;
      gap: 16px;
    }

    .form-group {
      display: grid;
      gap: 8px;
    }

    .form-group label,
    .checkbox-group label {
      font-size: 14px;
      font-weight: 700;
      color: #0f172a;
    }

    .form-group input,
    .form-group textarea,
    .list-head input {
      width: 100%;
      border: 1px solid #cbd5e1;
      border-radius: 14px;
      padding: 12px 14px;
      font-size: 14px;
      outline: none;
      font-family: inherit;
      background: #fff;
      color: #0f172a;
      transition: 0.2s ease;
    }

    .form-group input:focus,
    .form-group textarea:focus,
    .list-head input:focus {
      border-color: #22c55e;
      box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.12);
    }

    .checkbox-group {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .form-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .message {
      min-height: 20px;
      color: #ef4444;
      font-size: 14px;
      line-height: 1.7;
    }

    .message.success {
      color: #16a34a;
    }

    .list-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 14px;
      flex-wrap: wrap;
    }

    .list-head input {
      max-width: 320px;
    }

    .item-list {
      display: grid;
      gap: 16px;
    }

    .item-card {
      border: 1px solid #e2e8f0;
      border-radius: 18px;
      padding: 20px;
      display: grid;
      gap: 14px;
      background: #f8fafc;
    }

    .item-title {
      font-size: 22px;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: #0f172a;
      margin-bottom: 4px;
      line-height: 1.25;
    }

    .item-meta {
      color: #64748b;
      font-size: 14px;
      line-height: 1.8;
    }

    .item-description {
      color: #475569;
      line-height: 1.85;
      font-size: 14px;
      white-space: pre-wrap;
    }

    .item-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .empty {
      color: #64748b;
      font-size: 15px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 12px;
      padding: 12px 18px;
      font-weight: 700;
      text-decoration: none;
      border: none;
      cursor: pointer;
    }

    .btn-primary {
      background: #22c55e;
      color: white;
    }

    .btn-primary:hover {
      background: #16a34a;
    }

    .btn-danger {
      background: #ef4444;
      color: white;
    }

    .btn-danger:hover {
      background: #dc2626;
    }

    .btn-outline {
      background: white;
      color: #0f172a;
      border: 1px solid #e2e8f0;
    }

    .btn-outline:hover {
      background: #f8fafc;
    }

    @media (max-width: 980px) {
      .admin-layout {
        grid-template-columns: 1fr;
      }

      .form-card {
        position: static;
      }
    }
  </style>

  <script>
    // @ts-nocheck
    import { supabase } from "../../lib/supabase.js";
    import { requireSuperadmin } from "../../lib/admin-guard.js";

    const postForm = document.getElementById("postForm");
    const formTitle = document.getElementById("formTitle");
    const submitBtn = document.getElementById("submitBtn");
    const cancelEditBtn = document.getElementById("cancelEditBtn");
    const formMessage = document.getElementById("formMessage");
    const postList = document.getElementById("postList");
    const searchInput = document.getElementById("searchInput");
    const logoutBtn = document.getElementById("logoutBtn");

    const titleInput = document.getElementById("title");
    const slugInput = document.getElementById("slug");
    const contentInput = document.getElementById("content");
    const publishedInput = document.getElementById("published");

    let editingId = null;
    let posts = [];

    function setMessage(text, type = "error") {
      if (!formMessage) return;
      formMessage.textContent = text;
      formMessage.className = `message ${type === "success" ? "success" : ""}`;
    }

    function resetForm() {
      editingId = null;
      if (formTitle) formTitle.textContent = "Tambah Artikel";
      if (submitBtn) submitBtn.textContent = "Simpan Artikel";
      if (cancelEditBtn) cancelEditBtn.hidden = true;
      postForm?.reset();
      if (publishedInput) publishedInput.checked = true;
      setMessage("");
    }

    function fillForm(item) {
      editingId = item.id;
      if (formTitle) formTitle.textContent = "Edit Artikel";
      if (submitBtn) submitBtn.textContent = "Update Artikel";
      if (cancelEditBtn) cancelEditBtn.hidden = false;

      if (titleInput) titleInput.value = item.title || "";
      if (slugInput) slugInput.value = item.slug || "";
      if (contentInput) contentInput.value = item.content || "";
      if (publishedInput) publishedInput.checked = !!item.published;

      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    function renderPosts(data) {
      if (!postList) return;

      if (!data.length) {
        postList.innerHTML = `<p class="empty">Belum ada artikel.</p>`;
        return;
      }

      postList.innerHTML = data
        .map(
          (item) => `
            <div class="item-card">
              <div>
                <div class="item-title">${item.title || "-"}</div>
                <div class="item-meta">
                  Slug: ${item.slug || "-"} • ${item.published ? "Published" : "Draft"}
                </div>
              </div>

              <div class="item-description">
                ${(item.content || "Belum ada isi artikel.").slice(0, 250)}${
                  (item.content || "").length > 250 ? "..." : ""
                }
              </div>

              <div class="item-actions">
                <button class="btn btn-outline edit-btn" data-id="${item.id}">Edit</button>
                <button class="btn btn-danger delete-btn" data-id="${item.id}">Hapus</button>
              </div>
            </div>
          `
        )
        .join("");

      postList.querySelectorAll(".edit-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          const item = posts.find((row) => row.id === btn.dataset.id);
          if (item) fillForm(item);
        });
      });

      postList.querySelectorAll(".delete-btn").forEach((btn) => {
        btn.addEventListener("click", () => deletePost(btn.dataset.id));
      });
    }

    async function guardAdmin() {
      const result = await requireSuperadmin();
      return !!result;
    }

    async function loadPosts() {
      if (postList) {
        postList.innerHTML = `<p class="empty">Memuat artikel...</p>`;
      }

      const { data, error } = await supabase
        .from("posts")
        .select("*")
        .order("created_at", { ascending: false });

      if (error) {
        if (postList) {
          postList.innerHTML = `<p class="empty">Gagal memuat artikel: ${error.message}</p>`;
        }
        return;
      }

      posts = data || [];
      renderPosts(posts);
    }

    function getPayload() {
      return {
        title: titleInput?.value?.trim() || "",
        slug: slugInput?.value?.trim() || "",
        content: contentInput?.value?.trim() || "",
        published: !!publishedInput?.checked,
      };
    }

    async function createPost(payload) {
      return await supabase.from("posts").insert([payload]).select();
    }

    async function updatePost(id, payload) {
      return await supabase.from("posts").update(payload).eq("id", id).select();
    }

    async function deletePost(id) {
      const confirmed = confirm("Yakin ingin menghapus artikel ini?");
      if (!confirmed) return;

      const { error } = await supabase.from("posts").delete().eq("id", id);

      if (error) {
        alert("Gagal menghapus artikel: " + error.message);
        return;
      }

      if (editingId === id) resetForm();
      await loadPosts();
    }

    postForm?.addEventListener("submit", async (e) => {
      e.preventDefault();

      const payload = getPayload();

      if (!payload.title || !payload.slug) {
        setMessage("Judul dan slug wajib diisi.");
        return;
      }

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = editingId ? "Mengupdate..." : "Menyimpan...";
      }

      let result;
      if (editingId) {
        result = await updatePost(editingId, payload);
      } else {
        result = await createPost(payload);
      }

      if (result.error) {
        setMessage("Gagal menyimpan artikel: " + result.error.message);
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = editingId ? "Update Artikel" : "Simpan Artikel";
        }
        return;
      }

      setMessage(
        editingId ? "Artikel berhasil diperbarui." : "Artikel berhasil ditambahkan.",
        "success"
      );

      resetForm();

      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = "Simpan Artikel";
      }

      await loadPosts();
    });

    cancelEditBtn?.addEventListener("click", resetForm);

    searchInput?.addEventListener("input", () => {
      const keyword = searchInput.value.toLowerCase().trim();

      if (!keyword) {
        renderPosts(posts);
        return;
      }

      const filtered = posts.filter((item) => {
        return (
          (item.title || "").toLowerCase().includes(keyword) ||
          (item.slug || "").toLowerCase().includes(keyword)
        );
      });

      renderPosts(filtered);
    });

    logoutBtn?.addEventListener("click", async () => {
      const { error } = await supabase.auth.signOut();
      if (error) {
        alert("Logout gagal: " + error.message);
        return;
      }

      window.location.href = "/login";
    });

    const allowed = await guardAdmin();
    if (allowed) {
      resetForm();
      await loadPosts();
    }
  </script>
</BaseLayout>