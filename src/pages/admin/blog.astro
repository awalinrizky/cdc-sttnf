---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="CDC STT-NF | Kelola Blog">
  <section class="admin-manage-page">
    <div class="container">
      <header class="manage-header">
        <div class="header-info">
          <span class="eyebrow">Content Creator</span>
          <h1>Kelola Artikel Blog</h1>
          <p>Tulis dan publikasikan edukasi karier untuk mahasiswa.</p>
        </div>
        <div class="header-btns">
          <a href="/admin" class="btn-back">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Dashboard
          </a>
        </div>
      </header>

      <div class="manage-grid">
        <aside class="sidebar-form">
          <div class="glass-card">
            <h2 id="formTitle">Tulis Artikel</h2>
            <form id="postForm" class="modern-form">
              <div class="input-group">
                <label>Judul Artikel</label>
                <input type="text" id="title" required placeholder="Cth: Cara Lolos Interview" />
              </div>
              <div class="input-group">
                <label>Slug (URL)</label>
                <input type="text" id="slug" required placeholder="tips-magang-2026" />
              </div>
              <div class="input-group">
                <label>Isi Konten</label>
                <textarea id="content" rows="12" placeholder="Tulis sesuatu yang bermanfaat..."></textarea>
              </div>
              <div class="checkbox-box">
                <input type="checkbox" id="published" checked />
                <label for="published">Tampilkan di Publik</label>
              </div>
              <div class="form-actions">
                <button type="submit" id="submitBtn" class="btn-main">Simpan Konten</button>
                <button type="button" id="cancelEditBtn" class="btn-outline" hidden>Batal Edit</button>
              </div>
              <p id="formMessage" class="msg-box"></p>
            </form>
          </div>
        </aside>

        <main class="list-area">
          <div class="list-header">
            <h2>Daftar Artikel</h2>
            <div class="search-wrapper">
              <input type="text" id="searchInput" placeholder="Cari judul..." />
            </div>
          </div>
          <div id="postList" class="cards-feed">
            <div class="loading-state">Memuat data artikel...</div>
          </div>
        </main>
      </div>
    </div>

    <style is:global>
      :root {
        --brand: #4f46e5;
        --brand-dark: #3730a3;
        --bg-main: #f1f5f9;
        --text-dark: #0f172a;
        --text-muted: #475569;
        --border-color: #cbd5e1;
      }
      .admin-manage-page { background: var(--bg-main); min-height: 100vh; padding: 40px 0; font-family: 'Inter', sans-serif; color: var(--text-dark); }
      .container { width: min(100% - 32px, 1200px); margin-inline: auto; }
      .manage-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 32px; padding-bottom: 20px; border-bottom: 2px solid var(--border-color); }
      .header-info h1 { font-size: 32px; font-weight: 800; color: var(--text-dark); margin: 8px 0; letter-spacing: -0.02em; }
      .header-info p { color: var(--text-muted); font-size: 16px; font-weight: 500; }
      .eyebrow { background: #e0e7ff; color: #4338ca; padding: 6px 12px; border-radius: 6px; font-size: 12px; font-weight: 800; text-transform: uppercase; }
      .manage-grid { display: grid; grid-template-columns: 400px 1fr; gap: 32px; align-items: start; }
      .glass-card { background: white; border: 1px solid var(--border-color); border-radius: 16px; padding: 24px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
      .sidebar-form { position: sticky; top: 20px; }
      .modern-form { display: grid; gap: 16px; }
      .input-group { display: grid; gap: 6px; }
      .input-group label { font-size: 14px; font-weight: 700; color: var(--text-dark); }
      .input-group input, .input-group textarea { width: 100%; padding: 12px; border-radius: 8px; border: 1px solid var(--border-color); font-family: inherit; font-size: 14px; color: var(--text-dark); }
      .input-group input:focus, .input-group textarea:focus { border-color: var(--brand); outline: 2px solid #e0e7ff; }
      .checkbox-box { display: flex; align-items: center; gap: 8px; font-weight: 700; font-size: 14px; }
      .btn-main { background: var(--brand); color: white; border: none; padding: 14px; border-radius: 8px; font-weight: 700; cursor: pointer; transition: 0.2s; width: 100%; }
      .btn-main:hover { background: var(--brand-dark); transform: translateY(-1px); }
      .btn-back { display: flex; align-items: center; gap: 8px; background: white; color: var(--text-dark); padding: 10px 18px; border: 1px solid var(--border-color); border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 14px; }
      .btn-back:hover { background: #f8fafc; border-color: var(--text-dark); }
      .list-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
      .search-wrapper input { padding: 10px 16px; border-radius: 99px; border: 1px solid var(--border-color); width: 250px; font-size: 14px; }
      .cards-feed { display: grid; gap: 16px; }
      .item-card { background: white; padding: 20px; border-radius: 12px; border: 1px solid var(--border-color); transition: 0.2s; }
      .item-card:hover { border-color: var(--brand); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
      .item-card h3 { font-size: 18px; font-weight: 800; color: var(--text-dark); margin-bottom: 4px; }
      .item-meta { font-size: 13px; color: var(--text-muted); font-weight: 600; margin-bottom: 12px; }
      .item-actions { display: flex; gap: 10px; margin-top: 15px; border-top: 1px solid #f1f5f9; padding-top: 15px; }
      .btn-edit { background: #f1f5f9; color: var(--text-dark); border: 1px solid var(--border-color); padding: 8px 16px; border-radius: 6px; font-weight: 700; cursor: pointer; }
      .btn-delete { background: #fee2e2; color: #b91c1c; border: 1px solid #fecaca; padding: 8px 16px; border-radius: 6px; font-weight: 700; cursor: pointer; }
      .msg-box { font-size: 13px; font-weight: 700; margin-top: 10px; }
      @media (max-width: 1024px) { .manage-grid { grid-template-columns: 1fr; } .sidebar-form { position: static; } }
    </style>

    <script>
      // @ts-nocheck
      import { supabase } from "../../lib/supabase.js";
      import { requireAdmin } from "../../lib/adminGuard.js";

      const postForm = document.getElementById("postForm");
      const formTitle = document.getElementById("formTitle");
      const submitBtn = document.getElementById("submitBtn");
      const cancelEditBtn = document.getElementById("cancelEditBtn");
      const formMessage = document.getElementById("formMessage");
      const postList = document.getElementById("postList");
      const searchInput = document.getElementById("searchInput");

      const titleInput = document.getElementById("title");
      const slugInput = document.getElementById("slug");
      const contentInput = document.getElementById("content");
      const publishedInput = document.getElementById("published");

      let editingId = null;
      let posts = [];

      function setMessage(text, type = "error") {
        formMessage.textContent = text;
        formMessage.style.color = type === "success" ? "#15803d" : "#b91c1c";
      }

      function resetForm() {
        editingId = null;
        formTitle.textContent = "Tulis Artikel";
        submitBtn.textContent = "Simpan Konten";
        cancelEditBtn.hidden = true;
        postForm?.reset();
        publishedInput.checked = true;
        setMessage("");
      }

      function fillForm(item) {
        editingId = item.id;
        formTitle.textContent = "Edit Artikel";
        submitBtn.textContent = "Perbarui Konten";
        cancelEditBtn.hidden = false;
        titleInput.value = item.title || "";
        slugInput.value = item.slug || "";
        contentInput.value = item.content || "";
        publishedInput.checked = !!item.published;
        window.scrollTo({ top: 0, behavior: "smooth" });
      }

      function renderPosts(data) {
        if (!data.length) {
          postList.innerHTML = `<p style="text-align:center; padding: 40px; color:#64748b;">Belum ada artikel.</p>`;
          return;
        }
        postList.innerHTML = data.map(item => `
          <div class="item-card">
            <h3>${item.title || "Untitled"}</h3>
            <div class="item-meta">
              <span>Slug: /${item.slug}</span> • 
              <span style="color: ${item.published ? '#15803d' : '#b91c1c'}">${item.published ? 'Published' : 'Draft'}</span>
            </div>
            <div class="item-actions">
              <button class="btn-edit" data-id="${item.id}">Edit</button>
              <button class="btn-delete" data-id="${item.id}">Hapus</button>
            </div>
          </div>
        `).join("");

        postList.querySelectorAll(".btn-edit").forEach(btn => {
          btn.addEventListener("click", () => {
            const item = posts.find(p => p.id === btn.dataset.id);
            if (item) fillForm(item);
          });
        });

        postList.querySelectorAll(".btn-delete").forEach(btn => {
          btn.addEventListener("click", () => deletePost(btn.dataset.id));
        });
      }

      async function loadPosts() {
        const { data, error } = await supabase.from("posts").select("*").order("created_at", { ascending: false });
        if (error) return;
        posts = data || [];
        renderPosts(posts);
      }

      async function deletePost(id) {
        if (!confirm("Hapus artikel ini?")) return;
        await supabase.from("posts").delete().eq("id", id);
        loadPosts();
      }

      postForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        submitBtn.disabled = true;
        const payload = { title: titleInput.value.trim(), slug: slugInput.value.trim(), content: contentInput.value.trim(), published: publishedInput.checked };
        let res = editingId ? await supabase.from("posts").update(payload).eq("id", editingId) : await supabase.from("posts").insert([payload]);
        if (res.error) setMessage("Gagal: " + res.error.message);
        else { setMessage("Berhasil disimpan!", "success"); resetForm(); loadPosts(); }
        submitBtn.disabled = false;
      });

      cancelEditBtn?.addEventListener("click", resetForm);
      searchInput?.addEventListener("input", () => {
        const q = searchInput.value.toLowerCase();
        renderPosts(posts.filter(p => p.title.toLowerCase().includes(q)));
      });

      requireAdmin().then(ok => { if (ok) loadPosts(); });
    </script>
  </section>
</BaseLayout>