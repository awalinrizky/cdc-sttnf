---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="CDC STT-NF | Kelola Event">
  <section class="admin-manage-page">
    <div class="container">
      
      <header class="manage-header">
        <div class="header-info">
          <span class="eyebrow">Event Manager</span>
          <h1>Kelola Workshop & Event</h1>
          <p>Atur jadwal seminar, workshop, dan agenda karier mahasiswa.</p>
        </div>
        <div class="header-btns">
          <a href="/admin" class="btn-back">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Dashboard
          </a>
        </div>
      </header>

      <div class="manage-grid">
        <aside class="sidebar-form">
          <div class="glass-card">
            <h2 id="formTitle">Tambah Event</h2>
            <form id="eventForm" class="modern-form">
              <div class="input-group">
                <label for="title">Judul Event</label>
                <input type="text" id="title" required placeholder="Cth: Seminar Bedah CV ATS" />
              </div>

              <div class="input-group">
                <label for="location">Lokasi / Media</label>
                <input type="text" id="location" placeholder="Online / Zoom / Aula Kampus" />
              </div>

              <div class="input-group">
                <label for="date">Tanggal & Waktu</label>
                <input type="datetime-local" id="date" required />
              </div>

              <div class="input-group">
                <label for="registerUrl">Link Pendaftaran (URL)</label>
                <input type="url" id="registerUrl" placeholder="https://bit.ly/daftar-event" />
              </div>

              <div class="input-group">
                <label for="description">Deskripsi Singkat</label>
                <textarea id="description" rows="6" placeholder="Jelaskan detail acaranya..."></textarea>
              </div>

              <div class="checkbox-box">
                <input type="checkbox" id="isActive" checked />
                <label for="isActive">Tampilkan di Halaman Publik</label>
              </div>

              <div class="form-actions">
                <button type="submit" id="submitBtn" class="btn-main">Simpan Event</button>
                <button type="button" id="cancelEditBtn" class="btn-outline" hidden>Batal Edit</button>
              </div>

              <p id="formMessage" class="msg-box"></p>
            </form>
          </div>
        </aside>

        <main class="list-area">
          <div class="list-header">
            <h2>Daftar Agenda</h2>
            <div class="search-wrapper">
              <input type="text" id="searchInput" placeholder="Cari judul / lokasi..." />
            </div>
          </div>
          
          <div id="eventList" class="cards-feed">
            <div class="loading-state">Menghubungkan ke database...</div>
          </div>
        </main>
      </div>
    </div>

    <style is:global>
      :root {
        --brand: #4f46e5;
        --brand-dark: #3730a3;
        --bg-main: #f1f5f9;
        --text-dark: #0f172a;
        --text-muted: #475569;
        --border-color: #cbd5e1;
      }

      .admin-manage-page { background: var(--bg-main); min-height: 100vh; padding: 40px 0; font-family: 'Inter', sans-serif; color: var(--text-dark); }
      .container { width: min(100% - 32px, 1200px); margin-inline: auto; }

      /* Header */
      .manage-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 32px; padding-bottom: 20px; border-bottom: 2px solid var(--border-color); }
      .header-info h1 { font-size: 32px; font-weight: 800; color: var(--text-dark); margin: 8px 0; letter-spacing: -0.02em; }
      .header-info p { color: var(--text-muted); font-size: 16px; font-weight: 500; }
      .eyebrow { background: #e0e7ff; color: #4338ca; padding: 6px 12px; border-radius: 6px; font-size: 12px; font-weight: 800; text-transform: uppercase; }

      /* Layout */
      .manage-grid { display: grid; grid-template-columns: 400px 1fr; gap: 32px; align-items: start; }
      .sidebar-form { position: sticky; top: 20px; }
      .glass-card { background: white; border: 1px solid var(--border-color); border-radius: 16px; padding: 24px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }

      /* Form */
      .modern-form { display: grid; gap: 16px; }
      .input-group { display: grid; gap: 6px; }
      .input-group label { font-size: 14px; font-weight: 700; color: var(--text-dark); }
      .input-group input, .input-group textarea { width: 100%; padding: 12px; border-radius: 8px; border: 1px solid var(--border-color); font-family: inherit; font-size: 14px; color: var(--text-dark); }
      .input-group input:focus, .input-group textarea:focus { border-color: var(--brand); outline: 2px solid #e0e7ff; }
      .checkbox-box { display: flex; align-items: center; gap: 8px; font-weight: 700; font-size: 14px; padding: 10px; background: #f8fafc; border-radius: 8px; }

      /* Buttons */
      .btn-main { background: var(--brand); color: white; border: none; padding: 14px; border-radius: 8px; font-weight: 700; cursor: pointer; transition: 0.2s; width: 100%; }
      .btn-main:hover { background: var(--brand-dark); transform: translateY(-1px); }
      .btn-outline { background: white; border: 1px solid var(--border-color); color: var(--text-dark); padding: 12px; border-radius: 8px; font-weight: 700; cursor: pointer; width: 100%; }
      .btn-back { display: flex; align-items: center; gap: 8px; background: white; color: var(--text-dark); padding: 10px 18px; border: 1px solid var(--border-color); border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 14px; }
      .btn-back:hover { border-color: var(--text-dark); background: #f8fafc; }

      /* List Area */
      .list-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
      .search-wrapper input { padding: 10px 16px; border-radius: 99px; border: 1px solid var(--border-color); width: 250px; font-size: 14px; }
      .cards-feed { display: grid; gap: 16px; }
      .item-card { background: white; padding: 24px; border-radius: 12px; border: 1px solid var(--border-color); transition: 0.2s; position: relative; }
      .item-card:hover { border-color: var(--brand); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
      .item-card h3 { font-size: 20px; font-weight: 800; color: var(--text-dark); margin-bottom: 8px; line-height: 1.2; }
      .item-meta { font-size: 14px; color: var(--text-muted); font-weight: 600; margin-bottom: 12px; }
      .status-pill { position: absolute; top: 24px; right: 24px; padding: 4px 10px; border-radius: 999px; font-size: 11px; font-weight: 800; text-transform: uppercase; }
      .active-pill { background: #dcfce7; color: #15803d; }
      .inactive-pill { background: #fee2e2; color: #b91c1c; }

      .item-description { font-size: 14px; color: var(--text-muted); line-height: 1.6; margin-bottom: 16px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
      .item-actions { display: flex; gap: 10px; border-top: 1px solid #f1f5f9; padding-top: 15px; }
      .btn-edit-sm { background: #e0e7ff; color: var(--brand); border: none; padding: 8px 16px; border-radius: 6px; font-weight: 700; cursor: pointer; }
      .btn-delete-sm { background: #fee2e2; color: #b91c1c; border: none; padding: 8px 16px; border-radius: 6px; font-weight: 700; cursor: pointer; }

      .msg-box { font-size: 13px; font-weight: 700; text-align: center; margin-top: 10px; }
      @media (max-width: 1024px) { .manage-grid { grid-template-columns: 1fr; } .sidebar-form { position: static; } }
    </style>

    <script>
      // @ts-nocheck
      import { supabase } from "../../lib/supabase.js";
      import { requireAdmin } from "../../lib/adminGuard.js";

      const eventForm = document.getElementById("eventForm");
      const formTitle = document.getElementById("formTitle");
      const submitBtn = document.getElementById("submitBtn");
      const cancelEditBtn = document.getElementById("cancelEditBtn");
      const formMessage = document.getElementById("formMessage");
      const eventList = document.getElementById("eventList");
      const searchInput = document.getElementById("searchInput");

      const titleInput = document.getElementById("title");
      const locationInput = document.getElementById("location");
      const dateInput = document.getElementById("date");
      const registerUrlInput = document.getElementById("registerUrl");
      const descriptionInput = document.getElementById("description");
      const isActiveInput = document.getElementById("isActive");

      let editingId = null;
      let events = [];

      function setMessage(text, type = "error") {
        formMessage.textContent = text;
        formMessage.style.color = type === "success" ? "#15803d" : "#b91c1c";
      }

      function resetForm() {
        editingId = null;
        formTitle.textContent = "Tambah Event";
        submitBtn.textContent = "Simpan Event";
        cancelEditBtn.hidden = true;
        eventForm?.reset();
        isActiveInput.checked = true;
        setMessage("");
      }

      function fillForm(item) {
        editingId = item.id;
        formTitle.textContent = "Edit Event";
        submitBtn.textContent = "Update Event";
        cancelEditBtn.hidden = false;

        titleInput.value = item.title || "";
        locationInput.value = item.location || "";
        if (item.date) {
            const d = new Date(item.date);
            const offset = d.getTimezoneOffset() * 60000;
            const localDate = new Date(d.getTime() - offset).toISOString().slice(0, 16);
            dateInput.value = localDate;
        }
        registerUrlInput.value = item.register_url || "";
        descriptionInput.value = item.description || "";
        isActiveInput.checked = !!item.is_active;

        window.scrollTo({ top: 0, behavior: "smooth" });
      }

      function renderEvents(data) {
        if (!data.length) {
          eventList.innerHTML = `<p style="text-align:center; padding: 40px; color:#64748b;">Belum ada event terdaftar.</p>`;
          return;
        }

        eventList.innerHTML = data.map(item => {
          const dateStr = item.date ? new Date(item.date).toLocaleString('id-ID', { dateStyle: 'medium', timeStyle: 'short' }) : "-";
          return `
            <div class="item-card">
              <span class="status-pill ${item.is_active ? 'active-pill' : 'inactive-pill'}">
                ${item.is_active ? 'Aktif' : 'Nonaktif'}
              </span>
              <h3>${item.title}</h3>
              <div class="item-meta">
                📍 ${item.location || "Lokasi belum diatur"} • 📅 ${dateStr}
              </div>
              <div class="item-description">${item.description || "Tidak ada deskripsi."}</div>
              <div class="item-actions">
                <button class="btn-edit-sm" data-id="${item.id}">Edit</button>
                <button class="btn-delete-sm" data-id="${item.id}">Hapus</button>
              </div>
            </div>
          `;
        }).join("");

        eventList.querySelectorAll(".btn-edit-sm").forEach(btn => {
          btn.addEventListener("click", () => {
            const item = events.find(e => e.id === btn.dataset.id);
            if (item) fillForm(item);
          });
        });

        eventList.querySelectorAll(".btn-delete-sm").forEach(btn => {
          btn.addEventListener("click", () => deleteEvent(btn.dataset.id));
        });
      }

      async function loadEvents() {
        const { data, error } = await supabase.from("events").select("*").order("date", { ascending: true });
        if (error) return;
        events = data || [];
        renderEvents(events);
      }

      async function deleteEvent(id) {
        if (!confirm("Hapus event ini?")) return;
        await supabase.from("events").delete().eq("id", id);
        loadEvents();
      }

      eventForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        submitBtn.disabled = true;
        const payload = {
          title: titleInput.value.trim(),
          location: locationInput.value.trim(),
          date: dateInput.value,
          register_url: registerUrlInput.value.trim(),
          description: descriptionInput.value.trim(),
          is_active: isActiveInput.checked
        };

        let res = editingId ? await supabase.from("events").update(payload).eq("id", editingId) : await supabase.from("events").insert([payload]);
        
        if (res.error) setMessage("Gagal: " + res.error.message);
        else { setMessage("Berhasil disimpan!", "success"); resetForm(); loadEvents(); }
        submitBtn.disabled = false;
      });

      cancelEditBtn.addEventListener("click", resetForm);
      searchInput.addEventListener("input", () => {
        const q = searchInput.value.toLowerCase();
        renderEvents(events.filter(e => e.title.toLowerCase().includes(q) || e.location?.toLowerCase().includes(q)));
      });

      requireAdmin().then(ok => { if (ok) loadEvents(); });
    </script>
  </section>
</BaseLayout>