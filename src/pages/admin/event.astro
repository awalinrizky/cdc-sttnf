---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="CDC STT-NF | Kelola Event">
  <section class="admin-job-page">
    <div class="container">
      <div class="page-header">
        <div>
          <span class="eyebrow">Admin Panel</span>
          <h1>Kelola Workshop & Event</h1>
          <p class="subtext">
            Tambah, edit, hapus, dan atur event yang tampil di halaman workshop.
          </p>
        </div>

        <div class="page-actions">
          <a href="/admin" class="btn btn-outline">Kembali ke Dashboard</a>
          <button id="logoutBtn" class="btn btn-danger">Logout</button>
        </div>
      </div>

      <div class="layout-grid">
        <div class="form-card">
          <div class="card-head">
            <h2 id="formTitle">Tambah Event</h2>
            <p>Isi data workshop atau seminar dengan jelas.</p>
          </div>

          <form id="eventForm" class="job-form">
            <div class="form-group">
              <label for="title">Judul Event</label>
              <input type="text" id="title" required />
            </div>

            <div class="form-group">
              <label for="location">Lokasi</label>
              <input type="text" id="location" />
            </div>

            <div class="form-group">
              <label for="date">Tanggal Event</label>
              <input type="datetime-local" id="date" />
            </div>

            <div class="form-group">
              <label for="registerUrl">Link Pendaftaran</label>
              <input type="url" id="registerUrl" placeholder="https://..." />
            </div>

            <div class="form-group">
              <label for="description">Deskripsi</label>
              <textarea id="description" rows="6"></textarea>
            </div>

            <div class="checkbox-group">
              <input type="checkbox" id="isActive" checked />
              <label for="isActive">Tampilkan di publik</label>
            </div>

            <div class="form-actions">
              <button type="submit" id="submitBtn" class="btn btn-primary">
                Simpan Event
              </button>
              <button
                type="button"
                id="cancelEditBtn"
                class="btn btn-outline"
                hidden
              >
                Batal
              </button>
            </div>

            <p id="formMessage" class="message"></p>
          </form>
        </div>

        <div class="list-card">
          <div class="list-head">
            <div>
              <h2>Daftar Event</h2>
              <p>Kelola workshop dan seminar yang akan tampil ke publik.</p>
            </div>

            <input
              type="text"
              id="searchInput"
              placeholder="Cari judul / lokasi..."
            />
          </div>

          <div id="eventList" class="job-list">
            <p class="empty">Memuat data event...</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .container {
      width: min(100% - 32px, 1200px);
      margin-inline: auto;
    }

    .admin-job-page {
      padding: 48px 0 72px;
    }
    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
      flex-wrap: wrap;
      margin-bottom: 28px;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      padding: 8px 12px;
      border-radius: 999px;
      background: #dcfce7;
      color: #166534;
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 16px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    h1 {
      font-size: clamp(32px, 4vw, 48px);
      letter-spacing: -0.03em;
      margin-bottom: 10px;
      color: #0f172a;
    }

    .subtext {
      color: #64748b;
      line-height: 1.8;
      font-size: 16px;
      max-width: 720px;
    }

    .page-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .layout-grid {
      display: grid;
      grid-template-columns: 400px 1fr;
      gap: 24px;
      align-items: start;
    }

    .form-card,
    .list-card {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 22px;
      padding: 24px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
    }

    .card-head {
      margin-bottom: 18px;
    }

    .card-head h2,
    .list-head h2 {
      font-size: 26px;
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin-bottom: 8px;
    }

    .card-head p,
    .list-head p {
      color: #64748b;
      line-height: 1.8;
      font-size: 14px;
    }

    .job-form {
      display: grid;
      gap: 16px;
    }
    .form-group {
      display: grid;
      gap: 8px;
    }

    .form-group label,
    .checkbox-group label {
      font-size: 14px;
      font-weight: 700;
      color: #0f172a;
    }

    .form-group input,
    .form-group textarea,
    .list-head input {
      width: 100%;
      border: 1px solid #cbd5e1;
      border-radius: 14px;
      padding: 12px 14px;
      font-size: 14px;
      outline: none;
      font-family: inherit;
      background: #fff;
      color: #0f172a;
      transition: 0.2s ease;
    }

    .form-group input:focus,
    .form-group textarea:focus,
    .list-head input:focus {
      border-color: #22c55e;
      box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.12);
    }

    .checkbox-group {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .form-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .message {
      min-height: 20px;
      color: #ef4444;
      font-size: 14px;
      line-height: 1.7;
    }

    .message.success {
      color: #16a34a;
    }

    .list-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 14px;
      flex-wrap: wrap;
      margin-bottom: 18px;
    }

    .list-head input {
      max-width: 340px;
    }

    .job-list {
      display: grid;
      gap: 16px;
    }

    .job-item {
      border: 1px solid #e2e8f0;
      border-radius: 18px;
      padding: 20px;
      display: grid;
      gap: 14px;
      background: #f8fafc;
    }

    .job-top {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: flex-start;
      flex-wrap: wrap;
    }

    .job-title {
      font-size: 20px;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: #0f172a;
      margin-bottom: 4px;
    }

    .job-meta {
      color: #64748b;
      font-size: 14px;
      line-height: 1.8;
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
    }

    .status-active {
      background: #dcfce7;
      color: #166534;
    }

    .status-inactive {
      background: #fee2e2;
      color: #991b1b;
    }

    .job-description {
      color: #475569;
      line-height: 1.85;
      font-size: 14px;
      white-space: pre-wrap;
    }

    .job-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .empty {
      color: #64748b;
      font-size: 15px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 12px;
      padding: 12px 18px;
      font-weight: 700;
      text-decoration: none;
      border: none;
      cursor: pointer;
    }

    .btn-primary {
      background: #22c55e;
      color: white;
    }

    .btn-danger {
      background: #ef4444;
      color: white;
    }

    .btn-outline {
      background: white;
      color: #0f172a;
      border: 1px solid #e2e8f0;
    }

    @media (max-width: 980px) {
      .layout-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    // @ts-nocheck
    import { supabase } from "../../lib/supabase.js";
    import { requireAdmin } from "../../lib/admin-guard.js";

    const eventForm = document.getElementById("eventForm");
    const formTitle = document.getElementById("formTitle");
    const submitBtn = document.getElementById("submitBtn");
    const cancelEditBtn = document.getElementById("cancelEditBtn");
    const formMessage = document.getElementById("formMessage");
    const eventList = document.getElementById("eventList");
    const searchInput = document.getElementById("searchInput");
    const logoutBtn = document.getElementById("logoutBtn");

    const titleInput = document.getElementById("title");
    const locationInput = document.getElementById("location");
    const dateInput = document.getElementById("date");
    const registerUrlInput = document.getElementById("registerUrl");
    const descriptionInput = document.getElementById("description");
    const isActiveInput = document.getElementById("isActive");

    let editingId = null;
    let events = [];

    function setMessage(text, type = "error") {
      if (!formMessage) return;
      formMessage.textContent = text;
      formMessage.className = `message ${type === "success" ? "success" : ""}`;
    }

    function resetForm() {
      editingId = null;
      if (formTitle) formTitle.textContent = "Tambah Event";
      if (submitBtn) submitBtn.textContent = "Simpan Event";
      if (cancelEditBtn) cancelEditBtn.hidden = true;
      eventForm?.reset();
      if (isActiveInput) isActiveInput.checked = true;
      setMessage("");
    }

    function fillForm(eventItem) {
      editingId = eventItem.id;
      if (formTitle) formTitle.textContent = "Edit Event";
      if (submitBtn) submitBtn.textContent = "Update Event";
      if (cancelEditBtn) cancelEditBtn.hidden = false;

      if (titleInput) titleInput.value = eventItem.title || "";
      if (locationInput) locationInput.value = eventItem.location || "";
      if (dateInput && eventItem.date) {
        dateInput.value = new Date(eventItem.date).toISOString().slice(0, 16);
      }
      if (registerUrlInput)
        registerUrlInput.value = eventItem.register_url || "";
      if (descriptionInput)
        descriptionInput.value = eventItem.description || "";
      if (isActiveInput) isActiveInput.checked = !!eventItem.is_active;

      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    function renderEvents(data) {
      if (!eventList) return;

      if (!data.length) {
        eventList.innerHTML = `<p class="empty">Belum ada event.</p>`;
        return;
      }

      eventList.innerHTML = data
        .map(
          (eventItem) => `
            <div class="job-item">
              <div class="job-top">
                <div>
                  <div class="job-title">${eventItem.title || "-"}</div>
                  <div class="job-meta">
                    ${eventItem.location || "Lokasi belum diisi"} • ${eventItem.date ? new Date(eventItem.date).toLocaleString("id-ID") : "Tanggal belum diisi"}
                  </div>
                </div>
                <span class="status-badge ${eventItem.is_active ? "status-active" : "status-inactive"}">
                  ${eventItem.is_active ? "Aktif" : "Nonaktif"}
                </span>
              </div>

              <div class="job-description">
                ${eventItem.description || "Belum ada deskripsi."}
              </div>

              <div class="job-actions">
                <button class="btn btn-outline edit-btn" data-id="${eventItem.id}">Edit</button>
                <button class="btn btn-danger delete-btn" data-id="${eventItem.id}">Hapus</button>
              </div>
            </div>
          `,
        )
        .join("");

      eventList.querySelectorAll(".edit-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          const eventItem = events.find((item) => item.id === btn.dataset.id);
          if (eventItem) fillForm(eventItem);
        });
      });

      eventList.querySelectorAll(".delete-btn").forEach((btn) => {
        btn.addEventListener("click", () => deleteEvent(btn.dataset.id));
      });
    }

    async function guardAdmin() {
      const result = await requireAdmin();
      return !!result;

      if (!session) {
        window.location.href = "/login";
        return false;
      }

      const { data: profile } = await supabase
        .from("profiles")
        .select("role")
        .eq("id", session.user.id)
        .maybeSingle();

      if (!profile || profile.role !== "superadmin") {
        window.location.href = "/403";
        return false;
      }

      return true;
    }

    async function loadEvents() {
      if (eventList)
        eventList.innerHTML = `<p class="empty">Memuat data event...</p>`;

      const { data, error } = await supabase
        .from("events")
        .select("*")
        .order("date", { ascending: true });

      if (error) {
        if (eventList)
          eventList.innerHTML = `<p class="empty">Gagal memuat event: ${error.message}</p>`;
        return;
      }

      events = data || [];
      renderEvents(events);
    }

    function getPayload() {
      return {
        title: titleInput?.value?.trim() || "",
        location: locationInput?.value?.trim() || "",
        date: dateInput?.value || null,
        register_url: registerUrlInput?.value?.trim() || "",
        description: descriptionInput?.value?.trim() || "",
        is_active: !!isActiveInput?.checked,
      };
    }

    async function createEvent(payload) {
      return await supabase.from("events").insert([payload]).select();
    }

    async function updateEvent(id, payload) {
      return await supabase
        .from("events")
        .update(payload)
        .eq("id", id)
        .select();
    }

    async function deleteEvent(id) {
      const confirmed = confirm("Yakin ingin menghapus event ini?");
      if (!confirmed) return;

      const { error } = await supabase.from("events").delete().eq("id", id);

      if (error) {
        alert("Gagal menghapus event: " + error.message);
        return;
      }

      if (editingId === id) resetForm();
      await loadEvents();
    }

    eventForm?.addEventListener("submit", async (e) => {
      e.preventDefault();

      const payload = getPayload();

      if (!payload.title) {
        setMessage("Judul event wajib diisi.");
        return;
      }

      if (payload.register_url && !payload.register_url.startsWith("http")) {
        setMessage("Link pendaftaran harus diawali http:// atau https://");
        return;
      }

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = editingId ? "Mengupdate..." : "Menyimpan...";
      }

      let result;
      if (editingId) {
        result = await updateEvent(editingId, payload);
      } else {
        result = await createEvent(payload);
      }

      if (result.error) {
        setMessage("Gagal menyimpan event: " + result.error.message);
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = editingId ? "Update Event" : "Simpan Event";
        }
        return;
      }

      setMessage(
        editingId
          ? "Event berhasil diperbarui."
          : "Event berhasil ditambahkan.",
        "success",
      );
      resetForm();

      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = "Simpan Event";
      }

      await loadEvents();
    });

    cancelEditBtn?.addEventListener("click", resetForm);

    searchInput?.addEventListener("input", () => {
      const keyword = searchInput.value.toLowerCase().trim();

      if (!keyword) {
        renderEvents(events);
        return;
      }

      const filtered = events.filter(
        (eventItem) =>
          (eventItem.title || "").toLowerCase().includes(keyword) ||
          (eventItem.location || "").toLowerCase().includes(keyword),
      );

      renderEvents(filtered);
    });

    logoutBtn?.addEventListener("click", async () => {
      await supabase.auth.signOut();
      window.location.href = "/login";
    });

    const allowed = await guardAdmin();
    if (allowed) {
      resetForm();
      await loadEvents();
    }
  </script>
</BaseLayout>
