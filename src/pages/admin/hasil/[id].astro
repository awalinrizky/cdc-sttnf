---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { supabase } from "../../../lib/supabase.js";

export const prerender = false;
const { id } = Astro.params;

// 1. Tarik detail survey-nya (buat tau apa aja pertanyaannya)
const { data: survey, error: surveyError } = await supabase
  .from('surveys')
  .select('*')
  .eq('id', id)
  .single();

// 2. Tarik semua jawaban responden yang masuk ke survey ini
const { data: responses, error: responseError } = await supabase
  .from('responses')
  .select('*')
  .eq('survey_id', id)
  .order('submitted_at', { ascending: false });

// Kalau survey gak ketemu, tendang balik ke dashboard
if (surveyError || !survey) {
  return Astro.redirect('/admin/manage-survey');
}

const schema = survey.schema || [];
---

<BaseLayout title={`Hasil: ${survey.title} | Admin CDC`}>
  <div class="result-container">
    <header class="result-header">
      <div>
        <a href="/admin/manage-survey" class="back-link">← Kembali ke Kelola Survey</a>
        <h1 class="title">Hasil: {survey.title}</h1>
        <p class="subtitle">Total Responden: <strong>{responses?.length || 0}</strong> orang</p>
      </div>
      <button class="btn-primary" onclick="window.print()">🖨️ Cetak / PDF</button>
    </header>

    <div class="table-wrapper card">
      {responses && responses.length > 0 ? (
        <div class="scroll-table">
          <table>
            <thead>
              <tr>
                <th>No</th>
                <th>Tanggal Submit</th>
                {/* Bikin Judul Kolom otomatis dari JSON Schema */}
                {schema.map((q : any) => (
                  <th>{q.question}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {/* Looping semua jawaban responden */}
              {responses.map((res, index) => {
                const answers = res.answers || {};
                return (
                  <tr>
                    <td>{index + 1}</td>
                    <td>{new Date(res.submitted_at).toLocaleString('id-ID')}</td>
                    
                    {/* Cocokin ID pertanyaan sama ID Jawaban */}
                    {schema.map((q : any) => {
                      const answerValue = answers[q.id];
                      // Kalau bentuknya array (checkbox), kita gabungin pake koma
                      const displayValue = Array.isArray(answerValue) 
                        ? answerValue.join(', ') 
                        : (answerValue || '-');
                      
                      return <td>{displayValue}</td>;
                    })}
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="empty-state">
          <div class="icon">📊</div>
          <h3>Belum Ada Data</h3>
          <p>Belum ada alumni/mahasiswa yang mengisi kuesioner ini.</p>
        </div>
      )}
    </div>
  </div>

  <style>
    .result-container { padding: 40px 0; max-width: 1200px; margin: 0 auto; font-family: system-ui, -apple-system, sans-serif;}
    .result-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 32px; border-bottom: 1px solid #e2e8f0; padding-bottom: 24px; }
    .back-link { color: #64748b; text-decoration: none; font-size: 14px; font-weight: 600; margin-bottom: 12px; display: inline-block; transition: 0.2s;}
    .back-link:hover { color: #0f172a; }
    .title { font-size: 32px; font-weight: 800; color: #0f172a; margin-top: 8px;}
    .subtitle { color: #64748b; margin-top: 8px; font-size: 15px;}
    .subtitle strong { color: #0f172a; }

    .card { background: white; border: 1px solid #e2e8f0; border-radius: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.02); overflow: hidden;}
    .scroll-table { overflow-x: auto; } /* Biar tabel bisa digeser ke kanan kalo soalnya banyak */
    
    table { width: 100%; border-collapse: collapse; min-width: 800px;}
    th { background: #f8fafc; text-align: left; padding: 16px 24px; font-size: 13px; color: #475569; font-weight: 700; border-bottom: 1px solid #e2e8f0; white-space: nowrap;}
    td { padding: 16px 24px; border-bottom: 1px solid #f1f5f9; font-size: 14px; color: #334155;}
    
    .empty-state { text-align: center; padding: 60px 20px; }
    .empty-state .icon { font-size: 48px; margin-bottom: 16px; }
    .empty-state h3 { color: #0f172a; margin-bottom: 8px; }
    .empty-state p { color: #64748b; }

    .btn-primary { background: #0f172a; color: white; border: none; padding: 10px 20px; border-radius: 10px; font-weight: 700; cursor: pointer; transition: 0.2s; }
    .btn-primary:hover { background: #4f46e5; }
  </style>
</BaseLayout>