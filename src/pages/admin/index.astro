      </div>
    </div>

    <style>
      .container {
        width: min(100% - 32px, 1120px);
        margin-inline: auto;
      }

      .admin-page {
        padding: 48px 0 72px;
      }

      .admin-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 20px;
        flex-wrap: wrap;
        margin-bottom: 28px;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        padding: 8px 12px;
        border-radius: 999px;
        background: #dcfce7;
        color: #166534;
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 16px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }

      h1 {
        font-size: clamp(32px, 4vw, 48px);
        letter-spacing: -0.03em;
        margin-bottom: 10px;
        color: #0f172a;
        line-height: 1.05;
      }

      .subtext {
        max-width: 760px;
        color: #64748b;
        line-height: 1.8;
        font-size: 16px;
      }

      .header-actions {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
      }

      .role-badge {
        display: inline-flex;
        align-items: center;
        padding: 10px 14px;
        background: #f8fafc;
        color: #0f172a;
        border: 1px solid #e2e8f0;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
      }

      .summary-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 28px;
      }

      .summary-card {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 22px;
        padding: 24px;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
        display: grid;
        gap: 12px;
        min-height: 180px;
      }

      .summary-label {
        color: #64748b;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }

      .summary-value {
        font-size: 46px;
        font-weight: 800;
        line-height: 1;
        color: #0f172a;
        letter-spacing: -0.04em;
      }

      .summary-value.role-text {
        font-size: 28px;
        line-height: 1.2;
        text-transform: uppercase;
        word-break: break-word;
      }

      .summary-copy {
        color: #64748b;
        font-size: 14px;
        line-height: 1.8;
      }

      .dashboard-layout {
        display: grid;
        grid-template-columns: minmax(0, 2fr) 320px;
        gap: 24px;
        align-items: start;
      }

      .section-head {
        margin-bottom: 18px;
      }

      .section-head h2 {
        font-size: 28px;
        letter-spacing: -0.02em;
        margin-bottom: 8px;
        color: #0f172a;
      }

      .section-head p {
        color: #64748b;
        line-height: 1.8;
        font-size: 15px;
      }

      .module-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
      }

      .module-card {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 22px;
        padding: 24px;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
        display: flex;
        flex-direction: column;
        gap: 14px;
        min-height: 240px;
        transition: 0.2s ease;
      }

      .module-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 18px 34px rgba(15, 23, 42, 0.08);
      }

      .module-tag {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        padding: 8px 12px;
        border-radius: 999px;
        background: #f1f5f9;
        color: #0f172a;
        font-size: 12px;
        font-weight: 700;
      }

      .module-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
      }

      .module-card h3 {
        font-size: 24px;
        line-height: 1.3;
        letter-spacing: -0.02em;
        color: #0f172a;
        max-width: 70%;
      }

      .module-count {
        font-size: 30px;
        font-weight: 800;
        line-height: 1;
        color: #0f172a;
        letter-spacing: -0.03em;
        flex-shrink: 0;
      }

      .module-card p {
        color: #64748b;
        line-height: 1.8;
        font-size: 15px;
        flex: 1;
      }

      .account-card {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 22px;
        padding: 24px;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
        position: sticky;
        top: 100px;
      }

      .account-card h2 {
        font-size: 24px;
        margin-bottom: 18px;
        letter-spacing: -0.02em;
        color: #0f172a;
      }

      .account-grid {
        display: grid;
        gap: 14px;
      }

      .account-item {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 16px;
        display: grid;
        gap: 8px;
      }

      .account-item span {
        color: #64748b;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }

      .account-item strong {
        color: #0f172a;
        font-size: 16px;
        word-break: break-word;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: none;
        border-radius: 12px;
        padding: 12px 18px;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
      }

      .btn-primary {
        background: #22c55e;
        color: white;
      }

      .btn-primary:hover {
        background: #16a34a;
      }

      .btn-danger {
        background: #ef4444;
        color: white;
      }

      .btn-danger:hover {
        background: #dc2626;
      }

      @media (max-width: 1100px) {
        .dashboard-layout {
          grid-template-columns: 1fr;
        }

        .account-card {
          position: static;
        }
      }

      @media (max-width: 900px) {
        .admin-header {
          flex-direction: column;
        }

        .summary-grid {
          grid-template-columns: 1fr;
        }

        .module-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>

    <script>
      // @ts-nocheck
      import { supabase } from "../../lib/supabase.js";
      import { requireAdmin } from "../../lib/adminGuard.js";

      const roleBadge = document.getElementById("roleBadge");
      const userEmail = document.getElementById("userEmail");
      const userRole = document.getElementById("userRole");
      const userRoleCard = document.getElementById("userRoleCard");

      const jobCount = document.getElementById("jobCount");
      const activeCount = document.getElementById("activeCount");
      const eventCount = document.getElementById("eventCount");
      const postCount = document.getElementById("postCount");
      const roadmapCount = document.getElementById("roadmapCount");
      const kuesionerCount = document.getElementById("kuesionerCount"); // Ini elemen HTML

      const logoutBtn = document.getElementById("logoutBtn");

      async function guardAdmin() {
        const result = await requireAdmin();
        if (!result) return null;

        const { session, profile } = result;

        if (userEmail) userEmail.textContent = session.user.email || "-";
        if (userRole) userRole.textContent = profile.role;
        if (userRoleCard) userRoleCard.textContent = profile.role;
        if (roleBadge) roleBadge.textContent = profile.role.toUpperCase();

        // LOGIC MUNCULIN MENU SUPERADMIN
        const menuUsers = document.getElementById("menuUsers");
        if (profile.role === "superadmin" && menuUsers) {
          menuUsers.style.display = "inline-flex";
        }

        return result;
      }

      async function loadStats() {
        try {
          const [
            jobsResult,
            activeJobsResult,
            eventsResult,
            postsResult,
            roadmapsResult,
            kuesionerResult,
          ] = await Promise.all([
            supabase.from("jobs").select("*", { count: "exact", head: true }),
            supabase
              .from("jobs")
              .select("*", { count: "exact", head: true })
              .eq("is_active", true),
            supabase.from("events").select("*", { count: "exact", head: true }),
            supabase.from("posts").select("*", { count: "exact", head: true }),
            supabase
              .from("roadmaps")
              .select("*", { count: "exact", head: true }),
            supabase
              .from("kuesioner_hasil")
              .select("*", { count: "exact", head: true }),
          ]);

          // CEK ERROR (Buat jaga-jaga kalau RLS masih ngeblokir)
          if (kuesionerResult.error) {
            console.error(
              "Gagal ambil data kuesioner:",
              kuesionerResult.error.message,
            );
          }

          // AMBIL ANGKA DARI HASIL QUERY SUPABASE (Bukan dari elemen HTML)
          const totalJobs = jobsResult.count ?? 0;
          const totalEvents = eventsResult.count ?? 0;
          const totalPosts = postsResult.count ?? 0;
          const totalRoadmaps = roadmapsResult.count ?? 0;
          const totalResponden = kuesionerResult.count ?? 0;

          // MASUKKIN KE HTML
          if (jobCount) jobCount.textContent = String(totalJobs);
          if (eventCount) eventCount.textContent = String(totalEvents);
          if (postCount) postCount.textContent = String(totalPosts);
          if (roadmapCount) roadmapCount.textContent = String(totalRoadmaps);
          if (kuesionerCount)
            kuesionerCount.textContent = String(totalResponden);
        } catch (err) {
          console.error("Terjadi kesalahan loadStats:", err);
        }
      }

      logoutBtn?.addEventListener("click", async () => {
        const { error } = await supabase.auth.signOut();
        if (error) {
          alert("Logout gagal: " + error.message);
          return;
        }
        window.location.href = "/login";
      });

      const authResult = await guardAdmin();
      if (authResult) {
        await loadStats();
      }
    </script>
  </section>
</BaseLayout>
