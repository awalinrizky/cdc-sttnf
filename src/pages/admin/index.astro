        <div class="header-actions" style="display: flex; align-items: center; gap: 12px;">
          <span id="roleBadge" class="role-badge">Memuat role...</span>
          <a href="/admin/users" id="menuUsers" class="btn btn-outline" style="display: none; border-color: #3b82f6; color: #3b82f6; padding: 10px 16px;">Kelola Pengguna</a>
          <button id="logoutBtn" class="btn btn-danger" style="padding: 10px 16px;">Logout</button>
        </div>
        
      </div>
        <div class="summary-grid">
          <article class="summary-card">
            <span class="module-tag">Jobs</span>
            <span class="summary-label">Total Lowongan</span>
            <strong id="jobCount" class="summary-value">-</strong>
            <p class="summary-copy">
              Jumlah semua lowongan yang tersimpan di sistem
            </p>
            <a href="/admin/job" class="btn btn-primary">Masuk ke Lowongan</a>
          </article>

          <article class="summary-card">
            <span class="module-tag">Events</span>
            <span class="summary-label">Total Workshop & Event</span>
            <strong id="eventCount" class="summary-value">-</strong>
            <p class="summary-copy">
              Jumlah workshop dan event yang tersimpan di sistem
            </p>
            <a href="/admin/event" class="btn btn-primary">Masuk ke Event</a>
          </article>

          <article class="summary-card">
            <span class="module-tag">Blog</span>
            <span class="summary-label">Total Artikel Blog</span>
            <strong id="postCount" class="summary-value">-</strong>
            <p class="summary-copy">
              Jumlah artikel blog yang tersimpan di sistem
            </p>
            <a href="/admin/blog" class="btn btn-primary">Masuk ke Blog</a>
          </article>

          <article class="summary-card">
            <span class="module-tag">Roadmap</span>

            <span class="summary-label">Total Roadmap</span>
            <strong id="roadmapCount" class="summary-value">-</strong>
            <p class="summary-copy">
              Jumlah roadmap karier yang tersimpan di sistem
            </p>
            <a href="/admin/roadmap" class="btn btn-primary">Masuk ke Roadmap</a
            >
          </article>

          <article class="summary-card">
            <span
              class="module-tag"
              style="background: #fef08a; color: #854d0e;">SURVEY</span
            >
            <span class="summary-label">Tracer Study</span>
            <strong id="kuesionerCount" class="summary-value">0</strong>
            <p class="summary-copy">
              Kelola pertanyaan kuesioner berkode dan export hasil jawaban
              mahasiswa.
            </p>
            <a
              href="/admin/kuesioner"
              class="btn btn-primary"
              style="background: #eab308; color: black;">Kelola Kuesioner</a
            >
          </article>
        </div>

