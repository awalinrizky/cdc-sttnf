---
import BaseLayout from "../../layouts/BaseLayout.astro";

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<BaseLayout>
  <h1 class="text-3xl font-bold">CMS Admin CDC</h1>

  <h2 class="text-xl font-bold mt-8">Tambah Lowongan</h2>

  <form id="jobForm" class="space-y-2">
    <input id="title" placeholder="Judul" class="border p-2 w-full" />
    <input id="locationInput" placeholder="Lokasi" class="border p-2 w-full" />
    <textarea id="description" placeholder="Deskripsi" class="border p-2 w-full"></textarea>
    <button class="bg-green-600 text-white px-4 py-2">Tambah</button>
  </form>

  <h2 class="text-xl font-bold mt-10">Daftar Lowongan</h2>
  <div id="jobList"></div>

  <script type="module" define:vars={{ supabaseUrl, supabaseAnonKey }}>
    import { createClient } from "https://esm.sh/@supabase/supabase-js@2";

    const supabase = createClient(supabaseUrl, supabaseAnonKey);

    // 🔐 CEK SESSION
    const { data: sessionData } = await supabase.auth.getSession();

    if (!sessionData.session) {
      window.location.replace("/login");
    }

    // 🔄 LOAD DATA
    async function loadJobs() {
      const { data } = await supabase.from("jobs").select("*");

      const container = document.getElementById("jobList");
      container.innerHTML = "";

      data?.forEach((job) => {
        container.innerHTML += `
          <div class="bg-white p-4 mt-4 rounded shadow">
            <h3 class="font-bold">${job.title}</h3>
            <p>${job.location}</p>
          </div>
        `;
      });
    }

    loadJobs();

    // ➕ TAMBAH DATA
    const jobForm = document.getElementById("jobForm");

    jobForm.addEventListener("submit", async (e) => {
      e.preventDefault();

      const title = document.getElementById("title").value;
      const locationValue = document.getElementById("locationInput").value;
      const description = document.getElementById("description").value;

      await supabase.from("jobs").insert({
        title,
        location: locationValue,
        description
      });

      alert("Berhasil ditambahkan");
      jobForm.reset();
      loadJobs();
    });
  </script>
</BaseLayout>