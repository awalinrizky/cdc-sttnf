---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="CDC STT-NF | Dashboard Admin">
  <section class="admin-page">
    <div class="container">
      <div class="admin-header">
        <div>
          <p class="eyebrow">Admin Panel</p>
          <h1>Dashboard Admin</h1>
          <p class="subtext">Kelola lowongan kerja dan magang CDC STT-NF.</p>
        </div>

        <div class="header-actions">
          <span id="roleBadge" class="role-badge">Memuat role...</span>
          <button id="logoutBtn" class="btn btn-danger">Logout</button>
        </div>
      </div>

      <div class="grid">
        <div class="card">
          <h3>Total Lowongan</h3>
          <p id="jobCount" class="stat-value">-</p>
          <small>Jumlah semua data lowongan di sistem</small>
        </div>

        <div class="card">
          <h3>Lowongan Aktif</h3>
          <p id="activeCount" class="stat-value">-</p>
          <small>Hanya lowongan yang tampil di publik</small>
        </div>

        <div class="card">
          <h3>Manajemen</h3>
          <p class="card-copy">
            Masuk ke halaman kelola lowongan untuk tambah, edit, atau hapus data.
          </p>
          <a href="/admin/job" class="btn btn-primary">Kelola Lowongan</a>
        </div>
      </div>

      <div class="card user-card">
        <h3>Informasi Akun</h3>
        <p><strong>Email:</strong> <span id="userEmail">-</span></p>
        <p><strong>Role:</strong> <span id="userRole">-</span></p>
      </div>
    </div>
  </section>

  <style>
    .container {
      width: min(100% - 32px, 1120px);
      margin-inline: auto;
    }

    .admin-page {
      padding: 40px 0 64px;
    }

    .admin-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
      margin-bottom: 28px;
      flex-wrap: wrap;
    }

    .eyebrow {
      color: #16a34a;
      font-weight: 700;
      margin-bottom: 8px;
      text-transform: uppercase;
      font-size: 13px;
      letter-spacing: 0.08em;
    }

    h1 {
      font-size: 38px;
      margin-bottom: 8px;
    }

    .subtext {
      color: #64748b;
      line-height: 1.8;
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .role-badge {
      display: inline-flex;
      align-items: center;
      padding: 10px 14px;
      background: #dcfce7;
      color: #166534;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 700;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-bottom: 24px;
    }

    .card {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 18px;
      padding: 24px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
    }

    .card h3 {
      margin-bottom: 10px;
      font-size: 20px;
    }

    .stat-value {
      font-size: 42px;
      font-weight: 800;
      margin-bottom: 8px;
      color: #0f172a;
    }

    .card small,
    .card-copy,
    .user-card p {
      color: #64748b;
      line-height: 1.8;
    }

    .user-card p {
      margin-top: 8px;
    }

    @media (max-width: 900px) {
      .grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    // @ts-nocheck
    import { supabase } from "../../lib/supabase.js";

    const roleBadge = document.getElementById("roleBadge");
    const userEmail = document.getElementById("userEmail");
    const userRole = document.getElementById("userRole");
    const jobCount = document.getElementById("jobCount");
    const activeCount = document.getElementById("activeCount");
    const logoutBtn = document.getElementById("logoutBtn");

    async function guardAdmin() {
      const {
        data: { session },
        error: sessionError,
      } = await supabase.auth.getSession();

      if (sessionError) {
        alert("Session error: " + sessionError.message);
        window.location.href = "/login";
        return null;
      }

      if (!session) {
        window.location.href = "/login";
        return null;
      }

      const { data: profile, error: profileError } = await supabase
        .from("profiles")
        .select("role")
        .eq("id", session.user.id)
        .maybeSingle();

      console.log("ADMIN PROFILE:", {
        profile,
        profileError,
        userId: session.user.id,
      });

      if (profileError) {
        alert("Profile error: " + profileError.message);
        window.location.href = "/login";
        return null;
      }

      if (!profile) {
        alert("Profile admin tidak ditemukan.");
        window.location.href = "/login";
        return null;
      }

      if (profile.role !== "admin" && profile.role !== "superadmin") {
        window.location.href = "/403";
        return null;
      }

      if (userEmail) userEmail.textContent = session.user.email || "-";
      if (userRole) userRole.textContent = profile.role;
      if (roleBadge) roleBadge.textContent = profile.role.toUpperCase();

      return { session, profile };
    }

    async function loadStats() {
      const { count: totalJobs, error: totalError } = await supabase
        .from("jobs")
        .select("*", { count: "exact", head: true });

      const { count: activeJobs, error: activeError } = await supabase
        .from("jobs")
        .select("*", { count: "exact", head: true })
        .eq("is_active", true);

      console.log("LOAD STATS:", {
        totalJobs,
        activeJobs,
        totalError,
        activeError,
      });

      if (jobCount) jobCount.textContent = String(totalJobs ?? 0);
      if (activeCount) activeCount.textContent = String(activeJobs ?? 0);
    }

    logoutBtn?.addEventListener("click", async () => {
      const { error } = await supabase.auth.signOut();

      if (error) {
        alert("Logout gagal: " + error.message);
        return;
      }

      window.location.href = "/login";
    });

    const authResult = await guardAdmin();
    if (authResult) {
      await loadStats();
    }
  </script>
</BaseLayout>