---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="CDC STT-NF | Kelola Roadmap">
  <section class="admin-job-page">
    <div class="container">
      <div class="page-header">
        <div>
          <span class="eyebrow">Admin Panel</span>
          <h1>Kelola Roadmap</h1>
          <p class="subtext">
            Tambah, edit, hapus isi roadmap karier langsung dari dashboard.
          </p>
        </div>

        <div class="page-actions">
          <a href="/admin" class="btn btn-outline">Kembali ke Dashboard</a>
          <button id="logoutBtn" class="btn btn-danger">Logout</button>
        </div>
      </div>

      <div class="layout-grid">
        <div class="form-card">
          <div class="card-head">
            <h2 id="formTitle">Tambah Roadmap</h2>
            <p>Isi setiap level roadmap agar tampil rapi di halaman publik.</p>
          </div>

          <form id="roadmapForm" class="job-form">
            <div class="form-group">
              <label for="category">Kategori</label>
              <input
                type="text"
                id="category"
                placeholder="frontend / backend / design / data"
                required
              />
            </div>

            <div class="form-group">
              <label for="title">Judul</label>
              <input type="text" id="title" required />
            </div>

            <div class="form-group">
              <label for="intro">Intro</label>
              <textarea id="intro" rows="4"></textarea>
            </div>

            <div class="form-group">
              <label for="level1Title">Level 1 Title</label>
              <input type="text" id="level1Title" />
            </div>

            <div class="form-group">
              <label for="level1Desc">Level 1 Desc</label>
              <textarea id="level1Desc" rows="3"></textarea>
            </div>

            <div class="form-group">
              <label for="level2Title">Level 2 Title</label>
              <input type="text" id="level2Title" />
            </div>

            <div class="form-group">
              <label for="level2Desc">Level 2 Desc</label>
              <textarea id="level2Desc" rows="3"></textarea>
            </div>

            <div class="form-group">
              <label for="level3Title">Level 3 Title</label>
              <input type="text" id="level3Title" />
            </div>

            <div class="form-group">
              <label for="level3Desc">Level 3 Desc</label>
              <textarea id="level3Desc" rows="3"></textarea>
            </div>

            <div class="form-group">
              <label for="tools">Tools</label>
              <input type="text" id="tools" />
            </div>

            <div class="checkbox-group">
              <input type="checkbox" id="isActive" checked />
              <label for="isActive">Tampilkan di publik</label>
            </div>

            <div class="form-actions">
              <button type="submit" id="submitBtn" class="btn btn-primary"
                >Simpan Roadmap</button
              >
              <button
                type="button"
                id="cancelEditBtn"
                class="btn btn-outline"
                hidden>Batal</button
              >
            </div>

            <p id="formMessage" class="message"></p>
          </form>
        </div>

        <div class="list-card">
          <div class="list-head">
            <div>
              <h2>Daftar Roadmap</h2>
              <p>
                Kelola seluruh roadmap karier yang tampil di halaman publik.
              </p>
            </div>
            <input
              type="text"
              id="searchInput"
              placeholder="Cari kategori / judul..."
            />
          </div>

          <div id="roadmapList" class="job-list">
            <p class="empty">Memuat roadmap...</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .container {
      width: min(100% - 32px, 1200px);
      margin-inline: auto;
    }
    .admin-job-page {
      padding: 48px 0 72px;
    }
    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
      flex-wrap: wrap;
      margin-bottom: 28px;
    }
    .eyebrow {
      display: inline-flex;
      align-items: center;
      padding: 8px 12px;
      border-radius: 999px;
      background: #dcfce7;
      color: #166534;
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 16px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    h1 {
      font-size: clamp(32px, 4vw, 48px);
      letter-spacing: -0.03em;
      margin-bottom: 10px;
      color: #0f172a;
    }
    .subtext {
      color: #64748b;
      line-height: 1.8;
      font-size: 16px;
      max-width: 720px;
    }
    .page-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }
    .layout-grid {
      display: grid;
      grid-template-columns: 430px 1fr;
      gap: 24px;
      align-items: start;
    }
    .form-card,
    .list-card {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 22px;
      padding: 24px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
    }
    .card-head {
      margin-bottom: 18px;
    }
    .card-head h2,
    .list-head h2 {
      font-size: 26px;
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin-bottom: 8px;
    }
    .card-head p,
    .list-head p {
      color: #64748b;
      line-height: 1.8;
      font-size: 14px;
    }
    .job-form {
      display: grid;
      gap: 16px;
    }
    .form-group {
      display: grid;
      gap: 8px;
    }
    .form-group label,
    .checkbox-group label {
      font-size: 14px;
      font-weight: 700;
      color: #0f172a;
    }
    .form-group input,
    .form-group textarea,
    .list-head input {
      width: 100%;
      border: 1px solid #cbd5e1;
      border-radius: 14px;
      padding: 12px 14px;
      font-size: 14px;
      outline: none;
      font-family: inherit;
      background: #fff;
      color: #0f172a;
    }
    .checkbox-group {
      display: flex;
      gap: 10px;
      align-items: center;
    }
    .form-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .message {
      min-height: 20px;
      color: #ef4444;
      font-size: 14px;
      line-height: 1.7;
    }
    .message.success {
      color: #16a34a;
    }
    .list-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 14px;
      flex-wrap: wrap;
      margin-bottom: 18px;
    }
    .list-head input {
      max-width: 340px;
    }
    .job-list {
      display: grid;
      gap: 16px;
    }
    .job-item {
      border: 1px solid #e2e8f0;
      border-radius: 18px;
      padding: 20px;
      display: grid;
      gap: 14px;
      background: #f8fafc;
    }
    .job-title {
      font-size: 20px;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: #0f172a;
      margin-bottom: 4px;
    }
    .job-meta {
      color: #64748b;
      font-size: 14px;
      line-height: 1.8;
    }
    .job-description {
      color: #475569;
      line-height: 1.85;
      font-size: 14px;
      white-space: pre-wrap;
    }
    .job-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .empty {
      color: #64748b;
      font-size: 15px;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 12px;
      padding: 12px 18px;
      font-weight: 700;
      text-decoration: none;
      border: none;
      cursor: pointer;
    }
    .btn-primary {
      background: #22c55e;
      color: white;
    }
    .btn-danger {
      background: #ef4444;
      color: white;
    }
    .btn-outline {
      background: white;
      color: #0f172a;
      border: 1px solid #e2e8f0;
    }
    @media (max-width: 980px) {
      .layout-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    // @ts-nocheck
    import { supabase } from "../../lib/supabase.js";
    import { requireAdmin } from "../../lib/admin-guard.js";

    const roadmapForm = document.getElementById("roadmapForm");
    const formTitle = document.getElementById("formTitle");
    const submitBtn = document.getElementById("submitBtn");
    const cancelEditBtn = document.getElementById("cancelEditBtn");
    const formMessage = document.getElementById("formMessage");
    const roadmapList = document.getElementById("roadmapList");
    const searchInput = document.getElementById("searchInput");
    const logoutBtn = document.getElementById("logoutBtn");

    const categoryInput = document.getElementById("category");
    const titleInput = document.getElementById("title");
    const introInput = document.getElementById("intro");
    const level1TitleInput = document.getElementById("level1Title");
    const level1DescInput = document.getElementById("level1Desc");
    const level2TitleInput = document.getElementById("level2Title");
    const level2DescInput = document.getElementById("level2Desc");
    const level3TitleInput = document.getElementById("level3Title");
    const level3DescInput = document.getElementById("level3Desc");
    const toolsInput = document.getElementById("tools");
    const isActiveInput = document.getElementById("isActive");

    let editingId = null;
    let roadmaps = [];

    function setMessage(text, type = "error") {
      formMessage.textContent = text;
      formMessage.className = `message ${type === "success" ? "success" : ""}`;
    }

    function resetForm() {
      editingId = null;
      formTitle.textContent = "Tambah Roadmap";
      submitBtn.textContent = "Simpan Roadmap";
      cancelEditBtn.hidden = true;
      roadmapForm.reset();
      isActiveInput.checked = true;
      setMessage("");
    }

    function fillForm(item) {
      editingId = item.id;
      formTitle.textContent = "Edit Roadmap";
      submitBtn.textContent = "Update Roadmap";
      cancelEditBtn.hidden = false;

      categoryInput.value = item.category || "";
      titleInput.value = item.title || "";
      introInput.value = item.intro || "";
      level1TitleInput.value = item.level_1_title || "";
      level1DescInput.value = item.level_1_desc || "";
      level2TitleInput.value = item.level_2_title || "";
      level2DescInput.value = item.level_2_desc || "";
      level3TitleInput.value = item.level_3_title || "";
      level3DescInput.value = item.level_3_desc || "";
      toolsInput.value = item.tools || "";
      isActiveInput.checked = !!item.is_active;

      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    function renderRoadmaps(data) {
      if (!data.length) {
        roadmapList.innerHTML = `<p class="empty">Belum ada roadmap.</p>`;
        return;
      }

      roadmapList.innerHTML = data
        .map(
          (item) => `
            <div class="job-item">
              <div>
                <div class="job-title">${item.title || "-"}</div>
                <div class="job-meta">${item.category || "-"} • ${item.is_active ? "Aktif" : "Nonaktif"}</div>
              </div>

              <div class="job-description">
                ${item.intro || "Belum ada intro roadmap."}
              </div>

              <div class="job-actions">
                <button class="btn btn-outline edit-btn" data-id="${item.id}">Edit</button>
                <button class="btn btn-danger delete-btn" data-id="${item.id}">Hapus</button>
              </div>
            </div>
          `,
        )
        .join("");

      roadmapList.querySelectorAll(".edit-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          const item = roadmaps.find(
            (roadmap) => roadmap.id === btn.dataset.id,
          );
          if (item) fillForm(item);
        });
      });

      roadmapList.querySelectorAll(".delete-btn").forEach((btn) => {
        btn.addEventListener("click", () => deleteRoadmap(btn.dataset.id));
      });
    }

    async function guardAdmin() {
      const result = await requireAdmin();
      return !!result;

      if (!session) {
        window.location.href = "/login";
        return false;
      }

      const { data: profile } = await supabase
        .from("profiles")
        .select("role")
        .eq("id", session.user.id)
        .maybeSingle();

      if (!profile || profile.role !== "superadmin") {
        window.location.href = "/403";
        return false;
      }

      return true;
    }

    async function loadRoadmaps() {
      roadmapList.innerHTML = `<p class="empty">Memuat roadmap...</p>`;

      const { data, error } = await supabase
        .from("roadmaps")
        .select("*")
        .order("created_at", { ascending: false });

      if (error) {
        roadmapList.innerHTML = `<p class="empty">Gagal memuat roadmap: ${error.message}</p>`;
        return;
      }

      roadmaps = data || [];
      renderRoadmaps(roadmaps);
    }

    function getPayload() {
      return {
        category: categoryInput.value.trim(),
        title: titleInput.value.trim(),
        intro: introInput.value.trim(),
        level_1_title: level1TitleInput.value.trim(),
        level_1_desc: level1DescInput.value.trim(),
        level_2_title: level2TitleInput.value.trim(),
        level_2_desc: level2DescInput.value.trim(),
        level_3_title: level3TitleInput.value.trim(),
        level_3_desc: level3DescInput.value.trim(),
        tools: toolsInput.value.trim(),
        is_active: !!isActiveInput.checked,
      };
    }

    async function createRoadmap(payload) {
      return await supabase.from("roadmaps").insert([payload]).select();
    }

    async function updateRoadmap(id, payload) {
      return await supabase
        .from("roadmaps")
        .update(payload)
        .eq("id", id)
        .select();
    }

    async function deleteRoadmap(id) {
      const confirmed = confirm("Yakin ingin menghapus roadmap ini?");
      if (!confirmed) return;

      const { error } = await supabase.from("roadmaps").delete().eq("id", id);
      if (error) {
        alert("Gagal menghapus roadmap: " + error.message);
        return;
      }

      if (editingId === id) resetForm();
      await loadRoadmaps();
    }

    roadmapForm?.addEventListener("submit", async (e) => {
      e.preventDefault();

      const payload = getPayload();

      if (!payload.category || !payload.title) {
        setMessage("Kategori dan judul roadmap wajib diisi.");
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = editingId ? "Mengupdate..." : "Menyimpan...";

      let result;
      if (editingId) {
        result = await updateRoadmap(editingId, payload);
      } else {
        result = await createRoadmap(payload);
      }

      if (result.error) {
        setMessage("Gagal menyimpan roadmap: " + result.error.message);
        submitBtn.disabled = false;
        submitBtn.textContent = editingId ? "Update Roadmap" : "Simpan Roadmap";
        return;
      }

      setMessage(
        editingId
          ? "Roadmap berhasil diperbarui."
          : "Roadmap berhasil ditambahkan.",
        "success",
      );
      resetForm();
      submitBtn.disabled = false;
      submitBtn.textContent = "Simpan Roadmap";
      await loadRoadmaps();
    });

    cancelEditBtn?.addEventListener("click", resetForm);

    searchInput?.addEventListener("input", () => {
      const keyword = searchInput.value.toLowerCase().trim();

      if (!keyword) {
        renderRoadmaps(roadmaps);
        return;
      }

      const filtered = roadmaps.filter(
        (item) =>
          (item.title || "").toLowerCase().includes(keyword) ||
          (item.category || "").toLowerCase().includes(keyword),
      );

      renderRoadmaps(filtered);
    });

    logoutBtn?.addEventListener("click", async () => {
      await supabase.auth.signOut();
      window.location.href = "/login";
    });

    const allowed = await guardAdmin();
    if (allowed) {
      resetForm();
      await loadRoadmaps();
    }
  </script>
</BaseLayout>
