---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="CDC STT-NF | Kelola Lowongan">
  <section class="admin-manage-page">
    <div class="container">
      
      <header class="manage-header">
        <div class="header-info">
          <span class="eyebrow">Career Center</span>
          <h1>Kelola Lowongan Kerja</h1>
          <p>Manajemen informasi loker dan magang untuk alumni & mahasiswa STT-NF.</p>
        </div>
        <div class="header-btns">
          <a href="/admin" class="btn-back">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Dashboard
          </a>
        </div>
      </header>

      <div class="manage-grid">
        <aside class="sidebar-form">
          <div class="glass-card">
            <h2 id="formTitle">Tambah Lowongan</h2>
            <form id="jobForm" class="modern-form">
              <div class="input-group">
                <label for="title">Judul Pekerjaan</label>
                <input type="text" id="title" required placeholder="Cth: Fullstack Developer" />
              </div>

              <div class="input-group">
                <label for="companyName">Nama Perusahaan</label>
                <input type="text" id="companyName" placeholder="Cth: PT Teknologi Maju Indonesia" />
              </div>

              <div class="input-group">
                <label for="jobLocation">Lokasi Kerja</label>
                <input type="text" id="jobLocation" required placeholder="Cth: Jakarta / Remote" />
              </div>

              <div class="input-group">
                <label for="applyUrl">Link / Cara Melamar</label>
                <input type="text" id="applyUrl" placeholder="Email HRD atau URL Website" />
              </div>

              <div class="input-group">
                <label for="description">Deskripsi Pekerjaan</label>
                <textarea id="description" rows="8" placeholder="Tulis kualifikasi dan jobdesk..."></textarea>
              </div>

              <div class="checkbox-box">
                <input type="checkbox" id="isActive" checked />
                <label for="isActive">Publikasikan Lowongan</label>
              </div>

              <div class="form-actions">
                <button type="submit" id="submitBtn" class="btn-main">Simpan Lowongan</button>
                <button type="button" id="cancelEditBtn" class="btn-outline" hidden>Batal Edit</button>
              </div>

              <p id="formMessage" class="msg-box"></p>
            </form>
          </div>
        </aside>

        <main class="list-area">
          <div class="list-header">
            <h2>Daftar Lowongan Aktif</h2>
            <div class="search-wrapper">
              <input type="text" id="searchInput" placeholder="Cari posisi / perusahaan..." />
            </div>
          </div>
          
          <div id="jobList" class="cards-feed">
            <div class="loading-state">Menghubungkan ke server...</div>
          </div>
        </main>
      </div>
    </div>

    <style is:global>
      :root {
        --brand: #4f46e5;
        --brand-dark: #3730a3;
        --bg-main: #f1f5f9;
        --text-dark: #0f172a;
        --text-muted: #475569;
        --border-color: #cbd5e1;
      }

      .admin-manage-page { background: var(--bg-main); min-height: 100vh; padding: 40px 0; font-family: 'Inter', sans-serif; color: var(--text-dark); }
      .container { width: min(100% - 32px, 1200px); margin-inline: auto; }

      /* Header */
      .manage-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 32px; padding-bottom: 20px; border-bottom: 2px solid var(--border-color); }
      .header-info h1 { font-size: 32px; font-weight: 800; color: var(--text-dark); margin: 8px 0; letter-spacing: -0.02em; }
      .header-info p { color: var(--text-muted); font-size: 16px; font-weight: 500; }
      .eyebrow { background: #e0e7ff; color: #4338ca; padding: 6px 12px; border-radius: 6px; font-size: 12px; font-weight: 800; text-transform: uppercase; }

      /* Layout */
      .manage-grid { display: grid; grid-template-columns: 400px 1fr; gap: 32px; align-items: start; }
      .sidebar-form { position: sticky; top: 20px; }
      .glass-card { background: white; border: 1px solid var(--border-color); border-radius: 16px; padding: 24px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }

      /* Form */
      .modern-form { display: grid; gap: 16px; }
      .input-group { display: grid; gap: 6px; }
      .input-group label { font-size: 14px; font-weight: 700; color: var(--text-dark); }
      .input-group input, .input-group textarea { width: 100%; padding: 12px; border-radius: 8px; border: 1px solid var(--border-color); font-family: inherit; font-size: 14px; color: var(--text-dark); background: #fcfdfe; }
      .input-group input:focus, .input-group textarea:focus { border-color: var(--brand); outline: 2px solid #e0e7ff; background: white; }
      .checkbox-box { display: flex; align-items: center; gap: 8px; font-weight: 700; font-size: 14px; padding: 10px; background: #f8fafc; border-radius: 8px; border: 1px solid #e2e8f0; }

      /* Buttons */
      .btn-main { background: var(--brand); color: white; border: none; padding: 14px; border-radius: 8px; font-weight: 700; cursor: pointer; transition: 0.2s; width: 100%; }
      .btn-main:hover { background: var(--brand-dark); transform: translateY(-1px); }
      .btn-outline { background: white; border: 1px solid var(--border-color); color: var(--text-dark); padding: 12px; border-radius: 8px; font-weight: 700; cursor: pointer; width: 100%; margin-top: 8px; }
      .btn-back { display: flex; align-items: center; gap: 8px; background: white; color: var(--text-dark); padding: 10px 18px; border: 1px solid var(--border-color); border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 14px; transition: 0.2s; }
      .btn-back:hover { border-color: var(--text-dark); background: #f8fafc; }

      /* List Area */
      .list-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
      .search-wrapper input { padding: 10px 20px; border-radius: 99px; border: 1px solid var(--border-color); width: 280px; font-size: 14px; outline: none; }
      .search-wrapper input:focus { border-color: var(--brand); }
      
      .cards-feed { display: grid; gap: 16px; }
      .item-card { background: white; padding: 24px; border-radius: 16px; border: 1px solid var(--border-color); transition: 0.2s; position: relative; }
      .item-card:hover { border-color: var(--brand); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05); }
      
      .item-title-row { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; margin-bottom: 8px; }
      .item-card h3 { font-size: 20px; font-weight: 800; color: var(--text-dark); line-height: 1.2; margin: 0; }
      
      .status-pill { padding: 4px 10px; border-radius: 999px; font-size: 11px; font-weight: 800; text-transform: uppercase; }
      .status-active { background: #dcfce7; color: #15803d; }
      .status-inactive { background: #fee2e2; color: #b91c1c; }

      .item-meta { font-size: 14px; color: var(--text-muted); font-weight: 600; margin-bottom: 16px; }
      .item-actions { display: flex; gap: 10px; border-top: 1px solid #f1f5f9; padding-top: 16px; }
      .btn-edit-sm { background: #e0e7ff; color: var(--brand); border: none; padding: 8px 16px; border-radius: 6px; font-weight: 700; cursor: pointer; }
      .btn-delete-sm { background: #fee2e2; color: #b91c1c; border: none; padding: 8px 16px; border-radius: 6px; font-weight: 700; cursor: pointer; }

      .msg-box { font-size: 13px; font-weight: 700; text-align: center; margin-top: 10px; }
      .loading-state { text-align: center; padding: 40px; color: var(--text-muted); font-weight: 600; }

      @media (max-width: 1024px) { .manage-grid { grid-template-columns: 1fr; } .sidebar-form { position: static; } }
    </style>

    <script>
      // @ts-nocheck
      import { supabase } from "../../lib/supabase.js";
      import { requireAdmin } from "../../lib/adminGuard.js";

      const jobForm = document.getElementById("jobForm");
      const jobList = document.getElementById("jobList");
      const submitBtn = document.getElementById("submitBtn");
      const cancelEditBtn = document.getElementById("cancelEditBtn");
      const formTitle = document.getElementById("formTitle");
      const formMessage = document.getElementById("formMessage");
      const searchInput = document.getElementById("searchInput");

      let editingId = null;
      let jobs = [];

      function setMessage(text, type = "error") {
        formMessage.textContent = text;
        formMessage.style.color = type === "success" ? "#15803d" : "#b91c1c";
      }

      function resetForm() {
        editingId = null;
        formTitle.textContent = "Tambah Lowongan";
        submitBtn.textContent = "Simpan Lowongan";
        cancelEditBtn.hidden = true;
        jobForm?.reset();
        document.getElementById("isActive").checked = true;
        setMessage("");
      }

      function fillForm(job) {
        editingId = job.id;
        formTitle.textContent = "Edit Lowongan";
        submitBtn.textContent = "Update Lowongan";
        cancelEditBtn.hidden = false;

        document.getElementById("title").value = job.title || "";
        document.getElementById("companyName").value = job.company_name || "";
        document.getElementById("jobLocation").value = job.location || "";
        document.getElementById("applyUrl").value = job.apply_url || "";
        document.getElementById("description").value = job.description || "";
        document.getElementById("isActive").checked = !!job.is_active;

        window.scrollTo({ top: 0, behavior: "smooth" });
      }

      function renderJobs(data) {
        if (!data.length) {
          jobList.innerHTML = `<div class="loading-state">Tidak ada lowongan yang ditemukan.</div>`;
          return;
        }

        jobList.innerHTML = data.map(j => `
          <div class="item-card">
            <div class="item-title-row">
              <h3>${j.title}</h3>
              <span class="status-pill ${j.is_active ? 'status-active' : 'status-inactive'}">
                ${j.is_active ? 'Aktif' : 'Nonaktif'}
              </span>
            </div>
            <div class="item-meta">
              🏢 ${j.company_name || 'Perusahaan'} • 📍 ${j.location || '-'}
            </div>
            <div class="item-actions">
              <button class="btn-edit-sm" data-id="${j.id}">Edit</button>
              <button class="btn-delete-sm" data-id="${j.id}">Hapus</button>
            </div>
          </div>
        `).join("");

        jobList.querySelectorAll(".btn-edit-sm").forEach(btn => {
          btn.addEventListener("click", () => {
            const job = jobs.find(x => x.id === btn.dataset.id);
            if (job) fillForm(job);
          });
        });

        jobList.querySelectorAll(".btn-delete-sm").forEach(btn => {
          btn.addEventListener("click", () => deleteJob(btn.dataset.id));
        });
      }

      async function loadJobs() {
        const { data, error } = await supabase.from("jobs").select("*").order("created_at", { ascending: false });
        if (error) return;
        jobs = data || [];
        renderJobs(jobs);
      }

      async function deleteJob(id) {
        if (!confirm("Hapus lowongan ini secara permanen?")) return;
        await supabase.from("jobs").delete().eq("id", id);
        loadJobs();
      }

      jobForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        submitBtn.disabled = true;
        const payload = {
          title: document.getElementById("title").value.trim(),
          company_name: document.getElementById("companyName").value.trim(),
          location: document.getElementById("jobLocation").value.trim(),
          apply_url: document.getElementById("applyUrl").value.trim(),
          description: document.getElementById("description").value.trim(),
          is_active: document.getElementById("isActive").checked
        };

        let res;
        if (editingId) res = await supabase.from("jobs").update(payload).eq("id", editingId);
        else res = await supabase.from("jobs").insert([payload]);

        if (res.error) setMessage("Gagal: " + res.error.message);
        else { setMessage("Berhasil disimpan!", "success"); resetForm(); loadJobs(); }
        submitBtn.disabled = false;
      });

      cancelEditBtn.addEventListener("click", resetForm);
      
      searchInput.addEventListener("input", () => {
        const q = searchInput.value.toLowerCase();
        renderJobs(jobs.filter(j => 
          j.title.toLowerCase().includes(q) || 
          j.company_name?.toLowerCase().includes(q) ||
          j.location?.toLowerCase().includes(q)
        ));
      });

      requireAdmin().then(ok => { if (ok) loadJobs(); });
    </script>
  </section>
</BaseLayout>