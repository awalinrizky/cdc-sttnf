---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="CDC STT-NF | Kelola Pengguna">
  <section class="admin-page">
    <div class="container">
      <div class="page-header">
        <div>
          <span class="eyebrow">Superadmin Only</span>
          <h1>Kelola Pengguna</h1>
          <p class="subtext">Tambah Dosen atau Admin baru untuk mengelola konten CDC.</p>
        </div>
        <a href="/admin" class="btn btn-outline">Kembali ke Dashboard</a>
      </div>

      <div class="layout-grid" style="grid-template-columns: 400px 1fr;">
        <div class="form-card">
          <h2>Tambah Akun Baru</h2>
          <form id="userForm">
            <div class="form-group">
              <label>Email Dosen/Admin</label>
              <input type="email" id="email" required placeholder="dosen@nf.ac.id" />
            </div>
            <div class="form-group">
              <label>Password Awal</label>
              <input type="password" id="password" required placeholder="Minimal 6 karakter" />
            </div>
            <div class="form-group">
              <label>Role</label>
              <select id="role" class="form-select" style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #cbd5e1;">
                <option value="alumni">Alumni (Akses lihat konten)</option>
                <option value="admin">Admin (Konten saja)</option>
                <option value="superadmin">Superadmin (Konten + User)</option>
              </select>
            </div>
            <button type="submit" id="submitBtn" class="btn btn-primary" style="width: 100%; margin-top: 10px;">Buat Akun</button>
            <p id="msg" class="message"></p>
          </form>
        </div>

        <div class="list-card">
          <h2>Daftar Pengguna Aktif</h2>
          <div id="userList">Memuat daftar pengguna...</div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // @ts-nocheck
    import { supabase } from "../../lib/supabase.js";
    import { requireSuperAdmin } from "../../lib/adminGuard.js";

    const userForm = document.getElementById("userForm");
    const msg = document.getElementById("msg");
    const userList = document.getElementById("userList");
    let currentAdminId = "";

    async function loadUsers() {
      const { data, error } = await supabase.from("profiles").select("*").order("role");
      if (error) return userList.innerHTML = "Gagal memuat data.";
      
      userList.innerHTML = `
        <table style="width: 100%; border-collapse: collapse; margin-top: 10px;">
          <tr style="text-align: left; border-bottom: 2px solid #e2e8f0;">
            <th style="padding: 10px;">Email</th>
            <th style="padding: 10px;">Role</th>
          </tr>
          ${data.map(u => `
            <tr style="border-bottom: 1px solid #f1f5f9;">
              <td style="padding: 10px;">${u.email}</td>
              <td style="padding: 10px;"><span class="badge">${u.role.toUpperCase()}</span></td>
            </tr>
          `).join('')}
        </table>
      `;
    }

    userForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      msg.textContent = "Sedang memproses...";
      msg.style.color = "blue";

      const email = document.getElementById("email").value;
      const password = document.getElementById("password").value;
      const role = document.getElementById("role").value;

      // Panggil API Route yang kita bikin tadi
      const response = await fetch("/api/create-user", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, password, role, adminId: currentAdminId })
      });

      const result = await response.json();

      if (result.success) {
        msg.textContent = "Berhasil! Akun " + email + " sudah aktif.";
        msg.style.color = "green";
        userForm.reset();
        loadUsers();
      } else {
        msg.textContent = "Error: " + result.error;
        msg.style.color = "red";
      }
    });

    // Jalankan Satpam Khusus Superadmin
    requireSuperAdmin().then(res => {
      if (res) {
        currentAdminId = res.session.user.id;
        loadUsers();
      }
    });
  </script>
</BaseLayout>