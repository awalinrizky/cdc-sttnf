---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="CDC STT-NF | Beranda">
  <section class="hero">
    <div class="container hero-wrap">
      <div class="hero-copy">
        <span class="badge">Career Development Center</span>
        <h1>Mempersiapkan Mahasiswa & Alumni Menuju Dunia Kerja Profesional</h1>
        <p>
          CDC STT-NF membantu mahasiswa dan alumni menemukan lowongan kerja,
          magang, dan peluang pengembangan karier yang relevan.
        </p>

        <div class="hero-actions">
          <a href="/lowongan" class="btn btn-primary">Lihat Lowongan</a>
          <a href="/login" class="btn btn-outline">Masuk Admin</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Tentang CDC STT-NF</h2>
      <p class="section-text">
        CDC STT-NF merupakan unit yang mempersiapkan, melatih, dan menjadi wadah
        mahasiswa serta alumni dalam pengembangan karier, magang, dan koneksi ke
        dunia profesional.
      </p>
    </div>
  </section>

  <section class="section soft">
    <div class="container feature-grid">
      <div class="feature-card">
        <h3>Lowongan Terkurasi</h3>
        <p>Temukan peluang kerja dan magang yang lebih relevan untuk mahasiswa dan alumni.</p>
      </div>
      <div class="feature-card">
        <h3>Career Growth</h3>
        <p>Dukung perjalanan karier melalui akses informasi, training, dan peluang aktual.</p>
      </div>
      <div class="feature-card">
        <h3>Siap Terhubung</h3>
        <p>Bangun jembatan antara kampus, alumni, dan dunia kerja profesional.</p>
      </div>
    </div>
  </section>

  <style>
    .container {
      width: min(100% - 32px, 1120px);
      margin-inline: auto;
    }

    .hero {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      color: white;
      padding: 88px 0;
    }

    .hero-wrap {
      display: grid;
      grid-template-columns: 1fr;
      gap: 32px;
      align-items: center;
    }

    .hero-copy {
      max-width: 760px;
    }

    .badge {
      display: inline-block;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.15);
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 13px;
      margin-bottom: 20px;
    }

    .hero h1 {
      font-size: clamp(34px, 6vw, 56px);
      line-height: 1.05;
      margin-bottom: 16px;
      letter-spacing: -0.03em;
    }

    .hero p {
      font-size: 17px;
      line-height: 1.8;
      color: #cbd5e1;
      margin-bottom: 28px;
      max-width: 640px;
    }

    .hero-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
    }

    .section {
      padding: 72px 0;
    }

    .soft {
      background: #f1f5f9;
    }

    .section-title {
      font-size: 32px;
      margin-bottom: 16px;
      text-align: center;
    }

    .section-text {
      font-size: 16px;
      color: #475569;
      line-height: 1.9;
      max-width: 760px;
      margin: 0 auto;
      text-align: center;
    }

    .feature-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .feature-card {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 16px;
      padding: 24px;
      box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
    }

    .feature-card h3 {
      margin-bottom: 10px;
      font-size: 20px;
    }

    .feature-card p {
      color: #64748b;
      line-height: 1.8;
      font-size: 15px;
    }

    @media (max-width: 900px) {
      .feature-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>