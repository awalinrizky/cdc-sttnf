---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Roadmap Karier | CDC STT-NF">
  <section class="section">
    <div class="container">
      <h1>Roadmap Karier</h1>
      <p class="intro">
        Halaman ini berisi panduan jalur karier untuk mahasiswa dan alumni,
        seperti Frontend Developer, Backend Developer, UI/UX Designer, dan Data Analyst.
      </p>

      <div class="roadmap-grid">
        <div class="card">
          <h3>Frontend Developer</h3>
          <p>HTML, CSS, JavaScript, React, Astro, Git.</p>
        </div>

        <div class="card">
          <h3>Backend Developer</h3>
          <p>Node.js, API, Database, Auth, Deployment.</p>
        </div>

        <div class="card">
          <h3>UI/UX Designer</h3>
          <p>Design thinking, wireframe, prototype, Figma, usability testing.</p>
        </div>

        <div class="card">
          <h3>Data Analyst</h3>
          <p>Spreadsheet, SQL, Python, dashboard, data storytelling.</p>
        </div>
      </div>
    </div>
  </section>

  <style>
    .section {
      padding: 60px 0;
    }

    .intro {
      max-width: 720px;
      color: #64748b;
      line-height: 1.8;
      margin: 16px 0 28px;
    }

    .roadmap-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    .card {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 18px;
      padding: 24px;
    }

    @media (max-width: 900px) {
      .roadmap-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>   