---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Roadmap Karier | CDC STT-NF">
  <section class="hero-section">
    <div class="container hero-wrap">
      <span class="eyebrow">Roadmap Karier</span>
      <h1>Mulai dari arah yang jelas, lalu naik level dengan langkah yang terstruktur.</h1>
      <p>
        Roadmap ini membantu mahasiswa dan alumni memahami skill inti, tools utama,
        dan target output yang perlu dibangun untuk masuk ke dunia kerja.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2 class="section-title">Pilih Jalur Karier</h2>
        <p class="section-subtitle">
          Setiap jalur berisi fondasi belajar, teknologi utama, dan hasil portofolio yang bisa langsung kamu praktikkan.
        </p>
      </div>

      <div id="roadmapGrid" class="roadmap-grid">
        <p class="state-message">Memuat roadmap...</p>
      </div>
    </div>
  </section>

  <style is:global>
    .container { width: min(100% - 32px, 1120px); margin-inline: auto; }
    .hero-section {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      color: white; padding: 88px 0 76px;
    }
    .hero-wrap { max-width: 820px; }
    .eyebrow {
      display: inline-flex; align-items: center; padding: 8px 12px;
      border-radius: 999px; background: rgba(255,255,255,0.1); color: #dcfce7;
      font-size: 13px; font-weight: 700; letter-spacing: 0.04em;
      text-transform: uppercase; margin-bottom: 18px;
    }
    .hero-wrap h1 {
      font-size: clamp(34px, 5vw, 58px); line-height: 1.04;
      letter-spacing: -0.03em; margin-bottom: 16px;
    }
    .hero-wrap p {
      color: #cbd5e1; font-size: 17px; line-height: 1.9; max-width: 760px;
    }
    .section { padding: 72px 0; }
    .section-head { margin-bottom: 28px; }
    .section-title {
      font-size: clamp(28px, 4vw, 40px); margin-bottom: 12px;
      letter-spacing: -0.03em; color: #0f172a;
    }
    .section-subtitle {
      color: #64748b; line-height: 1.8; max-width: 720px; font-size: 16px;
    }
    .roadmap-grid {
      display: grid; grid-template-columns: repeat(2, 1fr); gap: 22px;
    }
    .roadmap-card {
      background: white; border: 1px solid #e2e8f0; border-radius: 22px;
      padding: 24px; box-shadow: 0 10px 30px rgba(15,23,42,0.05);
      display: flex; flex-direction: column; gap: 16px;
    }
    .tag {
      display: inline-flex; align-items: center; width: fit-content;
      padding: 8px 12px; border-radius: 999px; background: #f1f5f9;
      color: #0f172a; font-size: 12px; font-weight: 700;
    }
    .roadmap-card h3 {
      font-size: 24px; line-height: 1.28; letter-spacing: -0.02em; color: #0f172a;
    }
    .intro { color: #475569; font-size: 15px; line-height: 1.8; }
    .step-list { display: grid; gap: 12px; }
    .step-item {
      background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 16px; padding: 16px;
    }
    .step-item strong { display: block; margin-bottom: 8px; color: #0f172a; }
    .step-item p { color: #64748b; line-height: 1.8; font-size: 14px; }
    .tools { color: #0f172a; font-size: 14px; line-height: 1.8; font-weight: 600; }
    .state-message { color: #64748b; font-size: 16px; }
    @media (max-width: 900px) {
      .roadmap-grid { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    // @ts-nocheck
    import { supabase } from "../../lib/supabase.js";

    const roadmapGrid = document.getElementById("roadmapGrid");

    async function loadRoadmaps() {
      const { data, error } = await supabase
        .from("roadmaps")
        .select("*")
        .eq("is_active", true)
        .order("created_at", { ascending: false });

      if (error) {
        roadmapGrid.innerHTML = `<p class="state-message">Gagal memuat roadmap.</p>`;
        return;
      }

      if (!data || !data.length) {
        roadmapGrid.innerHTML = `<p class="state-message">Belum ada roadmap tersedia.</p>`;
        return;
      }

      roadmapGrid.innerHTML = data
        .map(
          (item) => `
            <article class="roadmap-card">
              <span class="tag">${item.category || "-"}</span>
              <h3>${item.title || "-"}</h3>
              <p class="intro">${item.intro || "Belum ada intro roadmap."}</p>

              <div class="step-list">
                <div class="step-item">
                  <strong>${item.level_1_title || "Level 1"}</strong>
                  <p>${item.level_1_desc || "-"}</p>
                </div>
                <div class="step-item">
                  <strong>${item.level_2_title || "Level 2"}</strong>
                  <p>${item.level_2_desc || "-"}</p>
                </div>
                <div class="step-item">
                  <strong>${item.level_3_title || "Level 3"}</strong>
                  <p>${item.level_3_desc || "-"}</p>
                </div>
              </div>

              <div class="tools">Tools: ${item.tools || "-"}</div>
            </article>
          `
        )
        .join("");
    }

    loadRoadmaps();
  </script>
</BaseLayout>
