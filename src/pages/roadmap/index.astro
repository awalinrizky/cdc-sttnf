---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Roadmap Karier | CDC STT-NF">
  <section class="hero-section">
    <div class="container hero-wrap">
      <span class="eyebrow">Roadmap Karier</span>
      <h1>Bangun fondasi skill-mu secara terstruktur</h1>
      <p>
        Panduan langkah demi langkah untuk membantu mahasiswa dan alumni memahami keahlian inti dan teknologi yang paling relevan dengan kebutuhan industri saat ini.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2 class="section-title">Pilih Jalur Karier</h2>
        <p class="section-subtitle">
          Temukan rute belajar yang paling sesuai dengan minatmu. Setiap roadmap dirancang agar kamu siap membangun portofolio profesional pertama.
        </p>
      </div>

      <div id="roadmapGrid" class="roadmap-grid">
        <div class="state-message">Menyiapkan roadmap untukmu...</div>
      </div>
    </div>
  </section>

  <style is:global>
    :root {
      --primary: #4f46e5;
      --slate-900: #0f172a;
      --slate-700: #334155;
      --slate-500: #64748b;
      --slate-200: #e2e8f0;
      --slate-50: #f8fafc;
    }

    .container { width: min(100% - 40px, 1100px); margin-inline: auto; }
    
    /* HERO SECTION */
    .hero-section {
      background: linear-gradient(145deg, var(--slate-900) 0%, #1e293b 100%);
      color: white; 
      padding: 100px 0 80px;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
    
    .hero-wrap { max-width: 800px; }
    
    .eyebrow {
      display: inline-flex; 
      align-items: center; 
      padding: 6px 14px;
      border-radius: 99px; 
      background: rgba(255, 255, 255, 0.1); 
      color: #cbd5e1;
      font-size: 13px; 
      font-weight: 700; 
      letter-spacing: 0.05em;
      text-transform: uppercase; 
      margin-bottom: 24px;
      border: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    .hero-wrap h1 {
      font-size: clamp(36px, 5vw, 56px); 
      line-height: 1.1;
      font-weight: 800;
      letter-spacing: -0.03em; 
      margin-bottom: 20px;
    }
    
    .hero-wrap p {
      color: #94a3b8; 
      font-size: 18px; 
      line-height: 1.7; 
      max-width: 700px;
    }

    /* MAIN CONTENT */
    .section { 
      padding: 80px 0 120px; 
      background-color: #fcfdfe;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
    
    .section-head { 
      margin-bottom: 48px; 
      text-align: center;
      max-width: 700px;
      margin-inline: auto;
    }
    
    .section-title {
      font-size: clamp(32px, 4vw, 42px); 
      font-weight: 800;
      margin-bottom: 16px;
      letter-spacing: -0.03em; 
      color: var(--slate-900);
    }
    
    .section-subtitle {
      color: var(--slate-500); 
      line-height: 1.7; 
      font-size: 17px;
    }

    /* GRID & CARD DESIGN (Lebih humanis, bukan AI) */
    .roadmap-grid {
      display: grid; 
      grid-template-columns: repeat(auto-fill, minmax(450px, 1fr)); 
      gap: 32px;
    }
    
    .roadmap-card {
      background: white; 
      border: 1px solid var(--slate-200); 
      border-radius: 24px;
      padding: 40px; 
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02), 0 2px 4px -1px rgba(0, 0, 0, 0.02);
      display: flex; 
      flex-direction: column; 
      gap: 24px;
      transition: all 0.3s ease;
    }

    .roadmap-card:hover {
      border-color: var(--primary);
      box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
      transform: translateY(-4px);
    }

    /* HEADER CARD */
    .card-header {
      border-bottom: 1px solid var(--slate-200);
      padding-bottom: 24px;
    }

    .tag {
      display: inline-flex; 
      padding: 6px 14px; 
      border-radius: 99px; 
      background: #eef2ff;
      color: var(--primary); 
      font-size: 12px; 
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 16px;
    }
    
    .card-header h3 {
      font-size: 26px; 
      font-weight: 800;
      line-height: 1.2; 
      letter-spacing: -0.02em; 
      color: var(--slate-900);
      margin-bottom: 12px;
      text-transform: capitalize;
    }
    
    .intro { 
      color: var(--slate-500); 
      font-size: 15px; 
      line-height: 1.7; 
    }

    /* TIMELINE / STEPS */
    .step-list { 
      display: flex; 
      flex-direction: column;
      gap: 16px; 
    }
    
    .step-item {
      background: var(--slate-50); 
      border: 1px solid var(--slate-200); 
      border-radius: 16px; 
      padding: 20px 24px;
      position: relative;
    }
    
    .step-label {
      display: inline-block;
      font-size: 11px;
      font-weight: 800;
      color: var(--slate-500);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 8px;
    }

    .step-item strong { 
      display: block; 
      margin-bottom: 6px; 
      color: var(--slate-900); 
      font-size: 17px;
      font-weight: 700;
      text-transform: capitalize;
    }
    
    .step-item p { 
      color: var(--slate-600); 
      line-height: 1.6; 
      font-size: 14px; 
    }
    
    /* FOOTER CARD */
    .tools-wrap { 
      margin-top: auto;
      padding-top: 24px;
      border-top: 1px dashed var(--slate-200);
    }

    .tools-title {
      font-size: 12px;
      font-weight: 700;
      color: var(--slate-500);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 8px;
    }

    .tools { 
      color: var(--slate-900); 
      font-size: 15px; 
      font-weight: 600; 
      line-height: 1.5;
    }
    
    .state-message { 
      grid-column: 1 / -1;
      text-align: center;
      padding: 80px 0;
      color: var(--slate-500); 
      font-size: 16px; 
      font-weight: 500;
    }

    @media (max-width: 768px) {
      .roadmap-grid { grid-template-columns: 1fr; }
      .roadmap-card { padding: 24px; }
    }
  </style>

  <script>
    // @ts-nocheck
    import { supabase } from "../../lib/supabase.js";

    const roadmapGrid = document.getElementById("roadmapGrid");

    async function loadRoadmaps() {
      const { data, error } = await supabase
        .from("roadmaps")
        .select("*")
        .eq("is_active", true)
        .order("created_at", { ascending: false });

      if (error) {
        if(roadmapGrid) roadmapGrid.innerHTML = `<p class="state-message">Gagal memuat roadmap: ${error.message}</p>`;
        return;
      }

      if (!data || !data.length) {
        if(roadmapGrid) roadmapGrid.innerHTML = `<p class="state-message">Belum ada roadmap yang tersedia saat ini.</p>`;
        return;
      }

      if(roadmapGrid) {
        roadmapGrid.innerHTML = data
          .map(
            (item) => `
              <article class="roadmap-card">
                <div class="card-header">
                  <span class="tag">${item.category || "General"}</span>
                  <h3>${item.title || "Jalur Karier Belum Dinamai"}</h3>
                  <p class="intro">${item.intro || "Panduan lengkap membangun keahlian di bidang ini secara bertahap."}</p>
                </div>

                <div class="step-list">
                  <div class="step-item">
                    <span class="step-label">Tahap 1 • Dasar</span>
                    <strong>${item.level_1_title || "Fondasi Belajar"}</strong>
                    <p>${item.level_1_desc || "Pahami konsep dasar yang akan menjadi pijakan utamamu."}</p>
                  </div>
                  <div class="step-item">
                    <span class="step-label">Tahap 2 • Menengah</span>
                    <strong>${item.level_2_title || "Eksplorasi Teknologi"}</strong>
                    <p>${item.level_2_desc || "Pelajari penggunaan tools inti dan mulai kerjakan proyek kecil."}</p>
                  </div>
                  <div class="step-item">
                    <span class="step-label">Tahap 3 • Mahir</span>
                    <strong>${item.level_3_title || "Spesialisasi"}</strong>
                    <p>${item.level_3_desc || "Kuasai teknik tingkat lanjut dan persiapkan portofolio untuk melamar kerja."}</p>
                  </div>
                </div>

                <div class="tools-wrap">
                  <div class="tools-title">Teknologi / Tools Utama</div>
                  <div class="tools">${item.tools || "Belum ada rekomendasi spesifik."}</div>
                </div>
              </article>
            `
          )
          .join("");
      }
    }
    
    loadRoadmaps();
  </script>
</BaseLayout>