---
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import { supabase } from "../lib/supabase.js";

const { data: jobs, error } = await supabase
  .from("jobs")
  .select("id, title, location, description, company_name, apply_url, is_active, created_at")
  .eq("is_active", true)
  .order("created_at", { ascending: false });
---

<BaseLayout title="CDC STT-NF | Lowongan">
  <section class="hero">
    <div class="container">
      <span class="badge">Lowongan & Magang</span>
      <h1>Temukan peluang karier terbaik untuk mahasiswa dan alumni</h1>
      <p>Cari lowongan berdasarkan posisi, perusahaan, atau lokasi.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="toolbar">
        <input
          type="text"
          id="searchInput"
          placeholder="Cari judul, perusahaan, atau lokasi..."
        />
      </div>

      {
        error ? (
          <div class="empty-state">
            <p>Gagal memuat lowongan. Silakan coba lagi nanti.</p>
          </div>
        ) : jobs && jobs.length > 0 ? (
          <div id="jobGrid" class="job-grid">
            {jobs.map((job) => (
              <article
                class="job-card"
                data-search={`${job.title ?? ""} ${job.company_name ?? ""} ${job.location ?? ""}`.toLowerCase()}
              >
                <div class="job-head">
                  <div>
                    <h3>{job.title}</h3>
                    <p class="company">{job.company_name || "Perusahaan belum diisi"}</p>
                  </div>
                  <span class="status">Aktif</span>
                </div>

                <p class="location">{job.location}</p>
                <p class="description">{job.description || "Belum ada deskripsi."}</p>

                <div class="actions">
                  <a href={`/lowongan/${job.id}`} class="btn btn-outline">Detail</a>
                  {job.apply_url ? (
                    <a href={job.apply_url} class="btn btn-primary" target="_blank" rel="noreferrer">
                      Apply
                    </a>
                  ) : (
                    <button class="btn btn-primary" disabled>Tidak ada link</button>
                  )}
                </div>
              </article>
            ))}
          </div>
        ) : (
          <div class="empty-state">
            <p>Belum ada lowongan tersedia.</p>
          </div>
        )
      }
    </div>
  </section>

  <style>
    .container {
      width: min(100% - 32px, 1120px);
      margin-inline: auto;
    }

    .hero {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      color: white;
      padding: 72px 0;
    }

    .badge {
      display: inline-block;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.14);
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 13px;
      margin-bottom: 16px;
    }

    .hero h1 {
      font-size: clamp(32px, 5vw, 52px);
      line-height: 1.08;
      margin-bottom: 12px;
      max-width: 760px;
    }

    .hero p {
      color: #cbd5e1;
      line-height: 1.8;
      max-width: 620px;
    }

    .section {
      padding: 48px 0 64px;
    }

    .toolbar {
      margin-bottom: 24px;
    }

    .toolbar input {
      width: 100%;
      max-width: 520px;
      border: 1px solid #cbd5e1;
      border-radius: 12px;
      padding: 13px 15px;
      font-size: 14px;
      outline: none;
      background: white;
    }

    .toolbar input:focus {
      border-color: #22c55e;
      box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.12);
    }

    .job-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .job-card {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 18px;
      padding: 22px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
      display: grid;
      gap: 14px;
    }

    .job-head {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: flex-start;
    }

    .job-card h3 {
      font-size: 20px;
      margin-bottom: 6px;
    }

    .company {
      color: #475569;
      font-size: 14px;
    }

    .status {
      background: #dcfce7;
      color: #166534;
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
      white-space: nowrap;
    }

    .location {
      color: #64748b;
      font-size: 14px;
      font-weight: 600;
    }

    .description {
      color: #475569;
      line-height: 1.8;
      font-size: 14px;
    }

    .actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 6px;
    }

    .empty-state {
      text-align: center;
      color: #64748b;
      padding: 50px 0;
      font-size: 15px;
    }

    @media (max-width: 980px) {
      .job-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 720px) {
      .job-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    const searchInput = document.getElementById("searchInput");
    const jobGrid = document.getElementById("jobGrid");

    if (searchInput instanceof HTMLInputElement && jobGrid instanceof HTMLElement) {
      const cards = Array.from(jobGrid.querySelectorAll(".job-card"));

      searchInput.addEventListener("input", () => {
        const keyword = searchInput.value.toLowerCase().trim();

        cards.forEach((card) => {
          if (!(card instanceof HTMLElement)) return;

          const haystack = card.getAttribute("data-search") || "";
          const visible = haystack.includes(keyword);
          card.style.display = visible ? "grid" : "none";
        });
      });
    }
  </script>
</BaseLayout>