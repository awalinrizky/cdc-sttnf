---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Lowongan Kerja | CDC STT-NF">
  <section class="hero-section">
    <div class="container hero-wrap">
      <span class="eyebrow">Karier</span>
      <h1>Lowongan Kerja & Magang</h1>
      <p>
        Temukan peluang kerja dan magang yang relevan untuk mahasiswa dan alumni
        STT-NF.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2 class="section-title">Daftar Lowongan</h2>
        <p class="section-subtitle">
          Jelajahi peluang terbaru yang tersedia dan pilih posisi yang sesuai
          dengan minat kariermu.
        </p>
      </div>

      <div id="jobList" class="job-grid">
        <p class="state-message">Memuat lowongan...</p>
      </div>
    </div>
  </section>

  <style is:global>
    .hero-section {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      color: white;
      padding: 88px 0 78px;
    }

    .hero-wrap {
      width: min(100% - 32px, 1120px);
      margin-inline: auto;
      max-width: 760px;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.1);
      color: #dcfce7;
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 18px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .hero-wrap h1 {
      font-size: clamp(34px, 5vw, 56px);
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin-bottom: 16px;
    }

    .hero-wrap p {
      color: #cbd5e1;
      line-height: 1.9;
      max-width: 680px;
      font-size: 17px;
    }

    .section {
      padding: 72px 0;
    }

    .section .container {
      width: min(100% - 32px, 1120px);
      margin-inline: auto;
    }

    .section-head {
      margin-bottom: 28px;
    }

    .section-title {
      font-size: clamp(28px, 4vw, 40px);
      margin-bottom: 12px;
      letter-spacing: -0.03em;
      color: #0f172a;
    }

    .section-subtitle {
      color: #64748b;
      line-height: 1.8;
      max-width: 720px;
      font-size: 16px;
    }

    .job-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
      align-items: stretch;
    }

    .job-card {
      background: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 22px;
      padding: 24px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
      display: flex;
      flex-direction: column;
      gap: 14px;
      min-height: 260px;
      transition: 0.2s ease;
    }

    .job-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 18px 34px rgba(15, 23, 42, 0.08);
    }

    .job-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 14px;
    }

    .job-title {
      font-size: 22px;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: #0f172a;
      line-height: 1.25;
      margin-bottom: 6px;
    }

    .job-company {
      color: #16a34a;
      font-weight: 700;
      font-size: 14px;
      line-height: 1.6;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      padding: 8px 12px;
      border-radius: 999px;
      background: #dcfce7;
      color: #166534;
      font-size: 12px;
      font-weight: 700;
      white-space: nowrap;
    }

    .job-meta {
      display: grid;
      gap: 8px;
      color: #475569;
      font-size: 14px;
      line-height: 1.8;
    }

    .job-meta strong {
      color: #0f172a;
    }

    .job-actions {
      margin-top: auto;
      padding-top: 8px;
    }

    .detail-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-weight: 700;
      color: #0f172a;
      text-decoration: none;
    }

    .detail-link:hover {
      color: #16a34a;
    }

    .state-message {
      color: #64748b;
      font-size: 16px;
    }

    @media (max-width: 960px) {
      .job-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 720px) {
      .job-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    // @ts-nocheck
    import { supabase } from "../../lib/supabase.js";

    const jobList = document.getElementById("jobList");

    async function loadJobs() {
      const { data, error } = await supabase
        .from("jobs")
        .select("*")
        .eq("is_active", true)
        .order("created_at", { ascending: false });

      if (error) {
        if (jobList) {
          jobList.innerHTML = `<p class="state-message">Gagal memuat lowongan.</p>`;
        }
        return;
      }

      if (!data || !data.length) {
        if (jobList) {
          jobList.innerHTML = `<p class="state-message">Belum ada lowongan tersedia.</p>`;
        }
        return;
      }

      jobList.innerHTML = data
        .map(
          (job) => `
            <article class="job-card">
              <div class="job-head">
                <div>
                  <div class="job-title">${job.title || "-"}</div>
                  <div class="job-company">${job.company_name || "Perusahaan belum diisi"}</div>
                </div>
                <span class="badge">Aktif</span>
              </div>

              <div class="job-meta">
                <div><strong>Lokasi:</strong> ${job.location || "-"}</div>
                <div><strong>Deskripsi:</strong> ${(job.description || "Belum ada deskripsi.").slice(0, 120)}${(job.description || "").length > 120 ? "..." : ""}</div>
              </div>

              <div class="job-actions">
                <a class="detail-link" href="/lowongan/detail?id=${job.id}">
                  Lihat Detail →
                </a>
              </div>
            </article>
          `
        )
        .join("");
    }

    loadJobs();
  </script>
</BaseLayout>