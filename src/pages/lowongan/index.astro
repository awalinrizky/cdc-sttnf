---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Lowongan Kerja | CDC STT-NF">
  <section class="section">
    <div class="container">
      <h1>Lowongan Kerja</h1>
      <div id="jobList" class="job-grid">
        <p class="empty-state">Memuat lowongan...</p>
      </div>
    </div>
  </section>

  <style>
    .section {
      padding: 60px 0;
    }

    .container {
      width: min(100% - 32px, 1120px);
      margin-inline: auto;
    }

    .job-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-top: 24px;
    }

    .job-card {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 16px;
      padding: 20px;
      box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
    }

    .job-card h3 {
      margin-bottom: 8px;
      font-size: 20px;
    }

    .job-card p {
      color: #64748b;
      line-height: 1.7;
      font-size: 14px;
      margin-bottom: 8px;
    }

    .job-card a {
      display: inline-block;
      margin-top: 10px;
      color: #16a34a;
      font-weight: 600;
    }

    .empty-state {
      color: #64748b;
      font-size: 16px;
    }

    @media (max-width: 900px) {
      .job-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    // @ts-nocheck
    import { supabase } from "../../lib/supabase.js";

    const jobList = document.getElementById("jobList");

    async function loadJobs() {
      const { data, error } = await supabase
        .from("jobs")
        .select("*")
        .eq("is_active", true)
        .order("created_at", { ascending: false });

      if (error) {
        if (jobList) {
          jobList.innerHTML = `<p class="empty-state">Gagal memuat lowongan.</p>`;
        }
        return;
      }

      if (!data || !data.length) {
        if (jobList) {
          jobList.innerHTML = `<p class="empty-state">Belum ada lowongan tersedia.</p>`;
        }
        return;
      }

      if (jobList) {
        jobList.innerHTML = data
          .map(
            (job) => `
              <article class="job-card">
                <h3>${job.title}</h3>
                <p><strong>Perusahaan:</strong> ${job.company_name || "-"}</p>
                <p><strong>Lokasi:</strong> ${job.location || "-"}</p>
                <a href="/lowongan/detail?id=${job.id}">Lihat Detail →</a>
              </article>
            `
          )
          .join("");
      }
    }

    loadJobs();
  </script>
</BaseLayout>