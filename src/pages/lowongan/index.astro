---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Lowongan Kerja & Magang | CDC STT-NF">
  <section class="hero-job">
    <div class="container hero-wrap">
      <span class="eyebrow-indigo">Karier & Peluang</span>
      <h1>Temukan Karier Impianmu di Sini</h1>
      <p>
        Eksplorasi berbagai peluang lowongan kerja dan program magang terbaik yang telah dikurasi khusus untuk mahasiswa dan alumni STT-NF.
      </p>
    </div>
  </section>

  <section class="job-feed-section">
    <div class="container">
      <div class="section-intro">
        <h2 class="section-title">Peluang Terbaru</h2>
        <p class="section-subtitle">Pilih posisi yang sesuai dengan minat dan kompetensi kariermu.</p>
      </div>

      <div id="jobList" class="job-grid-pro">
        <div class="loader-container">
            <div class="spinner"></div>
            <p>Mencari lowongan untukmu...</p>
        </div>
      </div>
    </div>
  </section>

  <style is:global>
    :root {
      --primary: #4f46e5;
      --primary-dark: #4338ca;
      --slate-900: #0f172a;
      --slate-700: #334155;
      --slate-500: #64748b;
      --emerald-600: #059669;
    }

    /* HERO STYLING */
    .hero-job {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      color: white;
      padding: 100px 0 80px;
    }

    .hero-wrap {
      width: min(100% - 32px, 800px);
      margin-inline: auto;
      text-align: center;
    }

    .eyebrow-indigo {
      display: inline-flex;
      padding: 8px 16px;
      border-radius: 99px;
      background: rgba(79, 70, 229, 0.15);
      color: #818cf8;
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      border: 1px solid rgba(129, 140, 248, 0.3);
      margin-bottom: 24px;
    }

    .hero-wrap h1 {
      font-size: clamp(34px, 5vw, 56px);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.04em;
      margin-bottom: 20px;
    }

    .hero-wrap p {
      color: #cbd5e1;
      font-size: 18px;
      line-height: 1.7;
    }

    /* FEED SECTION */
    .job-feed-section {
      padding: 80px 0 120px;
      background: #f8fafc;
      min-height: 500px;
    }

    .section-intro { margin-bottom: 40px; }
    .section-title { font-size: 32px; font-weight: 800; color: var(--slate-900); letter-spacing: -0.02em; }
    .section-subtitle { color: var(--slate-500); font-size: 16px; margin-top: 6px; }

    /* GRID & CARDS */
    .job-grid-pro {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
      gap: 24px;
    }

    .job-card-pro {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 24px;
      padding: 32px;
      display: flex;
      flex-direction: column;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      text-decoration: none;
    }

    .job-card-pro:hover {
      transform: translateY(-6px);
      border-color: var(--primary);
      box-shadow: 0 20px 25px -5px rgba(0,0,0,0.05);
    }

    .job-card-pro h3 {
      font-size: 22px;
      font-weight: 800;
      color: var(--slate-900);
      line-height: 1.3;
      margin-bottom: 8px;
    }

    .company-name {
      color: var(--emerald-600);
      font-weight: 700;
      font-size: 15px;
      margin-bottom: 16px;
      display: block;
    }

    .job-meta-list {
      display: grid;
      gap: 12px;
      margin-bottom: 24px;
      color: var(--slate-500);
      font-size: 14px;
    }

    .meta-item { display: flex; align-items: center; gap: 8px; font-weight: 500; }

    .job-excerpt {
      color: var(--slate-700);
      font-size: 15px;
      line-height: 1.6;
      margin-bottom: 24px;
      flex: 1;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* BADGE */
    .badge-job {
      display: inline-flex;
      padding: 4px 12px;
      border-radius: 6px;
      background: #eef2ff;
      color: var(--primary);
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      margin-bottom: 16px;
    }

    /* ACTION */
    .job-action-pro {
      display: flex;
      align-items: center;
      gap: 6px;
      color: var(--primary);
      font-weight: 700;
      font-size: 15px;
      margin-top: auto;
      padding-top: 16px;
      border-top: 1px solid #f1f5f9;
    }

    /* LOADING SPINNER */
    .loader-container { grid-column: 1 / -1; text-align: center; padding: 100px 0; color: var(--slate-500); }
    .spinner { width: 40px; height: 40px; border: 4px solid #e2e8f0; border-top-color: var(--primary); border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 16px; }
    @keyframes spin { to { transform: rotate(360deg); } }

    @media (max-width: 640px) {
      .job-grid-pro { grid-template-columns: 1fr; }
      .job-card-pro { padding: 24px; }
    }
  </style>

  <script>
    // @ts-nocheck
    import { supabase } from "../../lib/supabase.js";
    import { requireMahasiswa } from "../../lib/adminGuard.js";

    const jobList = document.getElementById("jobList");

    async function loadJobs() {
      const { data, error } = await supabase
        .from("jobs")
        .select("*")
        .eq("is_active", true)
        .order("created_at", { ascending: false });

      if (error) {
        jobList.innerHTML = `<p class="loader-container">Gagal memuat daftar lowongan.</p>`;
        return;
      }

      if (!data || !data.length) {
        jobList.innerHTML = `<p class="loader-container">Belum ada lowongan aktif saat ini.</p>`;
        return;
      }

      jobList.innerHTML = data.map(job => {
        const excerpt = job.description 
          ? job.description.substring(0, 100) + "..." 
          : "Klik untuk melihat detail kualifikasi lowongan ini.";

        return `
          <a href="/lowongan/detail?id=${job.id}" class="job-card-pro">
            <div class="badge-job">Hiring</div>
            <h3>${job.title}</h3>
            <span class="company-name">${job.company_name || 'Perusahaan Rahasia'}</span>
            
            <div class="job-meta-list">
              <div class="meta-item">
                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                ${job.location || 'Remote'}
              </div>
            </div>

            <p class="job-excerpt">${excerpt}</p>

            <div class="job-action-pro">
              Lihat Detail Pekerjaan
              <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </a>
        `;
      }).join("");
    }

    // Jalankan Satpam Mahasiswa
    requireMahasiswa().then(session => {
      if (session) loadJobs();
    });
  </script>
</BaseLayout>