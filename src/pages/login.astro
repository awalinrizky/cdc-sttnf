---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="CDC STT-NF | Login Admin">
  <section class="login-section">
    <div class="login-card">
      <h1>Login Admin</h1>
      <p>Masuk sebagai admin atau superadmin untuk mengelola lowongan.</p>

      <form id="loginForm" class="login-form">
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" placeholder="admin@email.com" required />
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" placeholder="••••••••" required />
        </div>

        <button type="submit" id="loginBtn" class="btn btn-primary full">
          Login
        </button>

        <p id="message" class="message"></p>
      </form>
    </div>
  </section>

  <style>
    .login-section {
      min-height: calc(100vh - 180px);
      display: grid;
      place-items: center;
      padding: 40px 16px;
    }

    .login-card {
      width: 100%;
      max-width: 420px;
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 18px;
      padding: 28px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
    }

    .login-card h1 {
      font-size: 28px;
      margin-bottom: 8px;
    }

    .login-card p {
      color: #64748b;
      line-height: 1.7;
      margin-bottom: 20px;
    }

    .login-form {
      display: grid;
      gap: 16px;
    }

    .form-group {
      display: grid;
      gap: 8px;
    }

    .form-group label {
      font-size: 14px;
      font-weight: 600;
    }

    .form-group input {
      width: 100%;
      border: 1px solid #cbd5e1;
      border-radius: 10px;
      padding: 12px 14px;
      font-size: 14px;
      outline: none;
    }

    .form-group input:focus {
      border-color: #22c55e;
      box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.12);
    }

    .full {
      width: 100%;
    }

    .message {
      min-height: 20px;
      font-size: 14px;
      color: #ef4444;
      margin: 0;
    }

    .message.success {
      color: #16a34a;
    }
  </style>

  <script type="module">
    import { supabase } from "../lib/supabase.js";

    const form = document.getElementById("loginForm");
    const emailInput = document.getElementById("email");
    const passwordInput = document.getElementById("password");
    const loginBtn = document.getElementById("loginBtn");
    const message = document.getElementById("message");

    function setMessage(text, type = "error") {
      message.textContent = text;
      message.className = `message ${type === "success" ? "success" : ""}`;
    }

    async function redirectIfAlreadyLoggedIn() {
      const {
        data: { session },
      } = await supabase.auth.getSession();

      if (!session) return;

      const { data: profile, error } = await supabase
        .from("profiles")
        .select("role")
        .eq("id", session.user.id)
        .single();

      if (error || !profile) {
        await supabase.auth.signOut();
        return;
      }

      if (profile.role === "admin" || profile.role === "superadmin") {
        window.location.href = "/admin";
      } else {
        await supabase.auth.signOut();
      }
    }

    redirectIfAlreadyLoggedIn();

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const email = emailInput.value.trim();
      const password = passwordInput.value;

      setMessage("");
      loginBtn.disabled = true;
      loginBtn.textContent = "Sedang login...";

      const { data, error } = await supabase.auth.signInWithPassword({
        email,
        password,
      });

      if (error) {
        setMessage("Login gagal: " + error.message);
        loginBtn.disabled = false;
        loginBtn.textContent = "Login";
        return;
      }

      const userId = data?.user?.id;

      if (!userId) {
        setMessage("Session login tidak valid.");
        loginBtn.disabled = false;
        loginBtn.textContent = "Login";
        return;
      }

      const { data: profile, error: profileError } = await supabase
        .from("profiles")
        .select("role")
        .eq("id", userId)
        .single();

      if (profileError || !profile) {
        await supabase.auth.signOut();
        setMessage("Profil user tidak ditemukan.");
        loginBtn.disabled = false;
        loginBtn.textContent = "Login";
        return;
      }

      if (profile.role !== "admin" && profile.role !== "superadmin") {
        await supabase.auth.signOut();
        setMessage("Akses ditolak. Akun ini bukan admin.");
        loginBtn.disabled = false;
        loginBtn.textContent = "Login";
        return;
      }

      setMessage("Login berhasil. Mengarahkan...", "success");
      window.location.href = "/admin";
    });
  </script>
</BaseLayout>