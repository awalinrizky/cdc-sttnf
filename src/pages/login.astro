---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
<h2 class="text-2xl font-bold">Login CMS Admin</h2>

<form id="loginForm" class="space-y-4 mt-6">
  <input type="email" id="email" placeholder="Email" class="border p-2 w-full"/>
  <input type="password" id="password" placeholder="Password" class="border p-2 w-full"/>
  <button class="bg-blue-600 text-white px-4 py-2">Login</button>
</form>

<script type="module">
  import { supabase } from "/src/lib/supabase.js";

  const form = document.getElementById("loginForm");

  form.addEventListener("submit", async (event) => {
    event.preventDefault();

    const email = document.getElementById("email").value;
    const password = document.getElementById("password").value;

    const { data, error } = await supabase.auth.signInWithPassword({
      email,
      password
    });

    if (error) {
      alert("Login gagal: " + error.message);
      return;
    }

    console.log("Login sukses:", data);

    // Redirect pakai cara paling aman
    window.location.href = "/admin";
  });
</script>

</BaseLayout>