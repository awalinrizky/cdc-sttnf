---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="CDC STT-NF | Login Admin">
  <section class="login-page">
    <div class="container login-container">
      
      <div class="login-content">
        <div class="brand-badge">
          <span class="dot"></span>
          CDC STT-NF Authority
        </div>
        <h1>Kelola Ekosistem Karier dalam Satu Panel</h1>
        <p>
          Masuk untuk memperbarui lowongan kerja, mengelola data kuesioner tracer study, 
          dan mempublikasikan edukasi karier terbaru untuk mahasiswa STT-NF.
        </p>
        <div class="auth-features">
          <div class="feature-item">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            <span>Secure Admin Authentication</span>
          </div>
          <div class="feature-item">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            <span>Real-time Data Management</span>
          </div>
        </div>
      </div>

      <div class="login-card-wrapper">
        <div class="login-card-pro">
          <div class="card-header">
            <h2>Selamat Datang</h2>
            <p>Silakan masuk menggunakan akun terdaftar</p>
          </div>

          <form id="loginForm" class="modern-form">
            <div class="input-group-pro">
              <label for="email">Alamat Email</label>
              <input type="email" id="email" placeholder="nama@nurulfikri.ac.id" required />
            </div>

            <div class="input-group-pro">
              <label for="password">Password</label>
              <input type="password" id="password" placeholder="••••••••" required />
            </div>

            <button type="submit" id="loginBtn" class="btn-login-glow">
              Masuk ke Dashboard
            </button>

            <p id="message" class="auth-message"></p>
          </form>
          
          <div class="card-footer-pro">
            <p>Butuh bantuan akses? Hubungi Tim IT STT-NF</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <style is:global>
    :root {
      --primary: #4f46e5;
      --primary-dark: #3730a3;
      --slate-900: #0f172a;
      --slate-600: #475569;
      --slate-200: #e2e8f0;
    }

    .login-page {
      background-color: #f8fafc;
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 40px 0;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .login-container {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 80px;
      align-items: center;
      width: min(100% - 32px, 1100px);
      margin-inline: auto;
    }

    /* LEFT SIDE CONTENT */
    .brand-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 14px;
      background: #eef2ff;
      color: var(--primary);
      border-radius: 99px;
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
      margin-bottom: 24px;
    }
    .dot { width: 6px; height: 6px; background: var(--primary); border-radius: 50%; }

    .login-content h1 {
      font-size: clamp(32px, 4vw, 46px);
      font-weight: 800;
      color: var(--slate-900);
      line-height: 1.1;
      letter-spacing: -0.04em;
      margin-bottom: 20px;
    }

    .login-content p {
      font-size: 17px;
      color: var(--slate-600);
      line-height: 1.7;
      margin-bottom: 32px;
    }

    .auth-features { display: grid; gap: 16px; }
    .feature-item { display: flex; align-items: center; gap: 12px; color: var(--slate-900); font-weight: 600; font-size: 14px; }
    .feature-item svg { color: var(--primary); }

    /* LOGIN CARD STYLE */
    .login-card-pro {
      background: white;
      border: 1px solid var(--slate-200);
      border-radius: 28px;
      padding: 48px;
      box-shadow: 0 20px 25px -5px rgba(0,0,0,0.05), 0 10px 10px -5px rgba(0,0,0,0.02);
    }

    .card-header { margin-bottom: 32px; }
    .card-header h2 { font-size: 26px; font-weight: 800; color: var(--slate-900); margin-bottom: 8px; }
    .card-header p { color: var(--slate-600); font-size: 15px; }

    .modern-form { display: grid; gap: 24px; }
    .input-group-pro { display: grid; gap: 8px; }
    .input-group-pro label { font-size: 14px; font-weight: 700; color: var(--slate-900); }
    .input-group-pro input {
      width: 100%;
      padding: 14px 18px;
      border-radius: 14px;
      border: 1.5px solid var(--slate-200);
      background: #fcfdfe;
      font-family: inherit;
      font-size: 15px;
      transition: all 0.2s;
    }
    .input-group-pro input:focus {
      outline: none;
      border-color: var(--primary);
      background: white;
      box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
    }

    .btn-login-glow {
      background: var(--primary);
      color: white;
      padding: 16px;
      border-radius: 14px;
      border: none;
      font-weight: 700;
      font-size: 16px;
      cursor: pointer;
      transition: all 0.2s;
      box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
    }
    .btn-login-glow:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(79, 70, 229, 0.4);
    }
    .btn-login-glow:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }

    .auth-message { font-size: 14px; font-weight: 700; text-align: center; margin: 0; min-height: 20px; }
    .auth-message.success { color: #15803d; }
    .auth-message.error { color: #b91c1c; }

    .card-footer-pro { margin-top: 32px; padding-top: 24px; border-top: 1px solid #f1f5f9; text-align: center; }
    .card-footer-pro p { font-size: 13px; color: var(--slate-500); font-weight: 500; }

    @media (max-width: 960px) {
      .login-container { grid-template-columns: 1fr; gap: 40px; text-align: center; }
      .brand-badge, .auth-features { justify-content: center; }
      .login-content p { margin-inline: auto; }
      .login-card-pro { padding: 32px; }
    }
  </style>

  <script>
    // @ts-nocheck
    import { supabase } from "../lib/supabase.js";

    const form = document.getElementById("loginForm");
    const emailInput = document.getElementById("email");
    const passwordInput = document.getElementById("password");
    const loginBtn = document.getElementById("loginBtn");
    const message = document.getElementById("message");

    function setMessage(text, isSuccess = false) {
      if (!message) return;
      message.textContent = text;
      message.className = `auth-message ${isSuccess ? 'success' : 'error'}`;
    }

    // Cek session saat ini
    async function checkSession() {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) return;

      const { data: profile } = await supabase
        .from("profiles")
        .select("role")
        .eq("id", session.user.id)
        .maybeSingle();

      if (profile && (profile.role === "admin" || profile.role === "superadmin")) {
        window.location.href = "/admin";
      }
    }

    checkSession();

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      setMessage("");

      const email = emailInput.value.trim();
      const password = passwordInput.value;

      loginBtn.disabled = true;
      loginBtn.textContent = "Mengautentikasi...";

      const { data, error } = await supabase.auth.signInWithPassword({ email, password });

      if (error) {
        setMessage("Login gagal: " + error.message);
        loginBtn.disabled = false;
        loginBtn.textContent = "Masuk ke Dashboard";
        return;
      }

      // Verifikasi Role
      const { data: profile, error: pError } = await supabase
        .from("profiles")
        .select("role")
        .eq("id", data.user.id)
        .maybeSingle();

      if (pError || !profile || (profile.role !== "admin" && profile.role !== "superadmin")) {
        setMessage("Akses ditolak. Anda tidak memiliki izin Admin.");
        await supabase.auth.signOut();
        loginBtn.disabled = false;
        loginBtn.textContent = "Masuk ke Dashboard";
        return;
      }

      setMessage("Autentikasi berhasil! Mengalihkan...", true);
      setTimeout(() => { window.location.href = "/admin"; }, 1000);
    });
  </script>
</BaseLayout>