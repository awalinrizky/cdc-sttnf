---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="CDC STT-NF | Login Admin">
  <section class="login-shell">
    <div class="container login-wrap">
      <div class="login-copy">
        <span class="page-eyebrow">Admin Access</span>
        <h1>Kelola data CDC dari panel admin yang rapi dan terstruktur</h1>
        <p>
          Masuk sebagai admin atau superadmin untuk mengelola lowongan, memperbarui data,
          dan memastikan informasi publik selalu relevan.
        </p>
      </div>

      <div class="login-card">
        <h2>Login Admin</h2>
        <p class="card-copy">Gunakan akun admin yang terdaftar di Supabase Auth</p>

        <form id="loginForm" class="login-form">
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" placeholder="admin@email.com" required />
          </div>

          <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" placeholder="••••••••" required />
          </div>

          <button type="submit" id="loginBtn" class="btn btn-primary full">
            Login
          </button>

          <p id="message" class="message"></p>
        </form>
      </div>
    </div>
  </section>

  <style>
    .login-shell {
      padding: 72px 0;
    }

    .login-wrap {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 28px;
      align-items: center;
    }

    .login-copy h1 {
      font-size: clamp(34px, 5vw, 52px);
      line-height: 1.06;
      letter-spacing: -0.03em;
      margin-bottom: 16px;
    }

    .login-copy p {
      color: #64748b;
      line-height: 1.9;
      font-size: 16px;
      max-width: 620px;
    }

    .login-card {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 22px;
      padding: 28px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
    }

    .login-card h2 {
      font-size: 28px;
      margin-bottom: 8px;
      letter-spacing: -0.02em;
    }

    .card-copy {
      color: #64748b;
      line-height: 1.7;
      margin-bottom: 20px;
      font-size: 14px;
    }

    .login-form {
      display: grid;
      gap: 16px;
    }

    .form-group {
      display: grid;
      gap: 8px;
    }

    .form-group label {
      font-size: 14px;
      font-weight: 700;
    }

    .form-group input {
      width: 100%;
      border: 1px solid #cbd5e1;
      border-radius: 14px;
      padding: 12px 14px;
      font-size: 14px;
      outline: none;
      transition: 0.2s ease;
    }

    .form-group input:focus {
      border-color: #22c55e;
      box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.12);
    }

    .full {
      width: 100%;
    }

    .message {
      min-height: 20px;
      font-size: 14px;
      color: #ef4444;
      margin: 0;
      line-height: 1.7;
    }

    .message.success {
      color: #16a34a;
    }

    @media (max-width: 900px) {
      .login-wrap {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    // @ts-nocheck
    import { supabase } from "../lib/supabase.js";

    const form = document.getElementById("loginForm");
    const emailInput = document.getElementById("email");
    const passwordInput = document.getElementById("password");
    const loginBtn = document.getElementById("loginBtn");
    const message = document.getElementById("message");

    function setMessage(text, type = "error") {
      if (!message) return;
      message.textContent = text;
      message.className = `message ${type === "success" ? "success" : ""}`;
    }

    async function checkCurrentSession() {
      const {
        data: { session },
      } = await supabase.auth.getSession();

      if (!session) return;

      const { data: profile } = await supabase
        .from("profiles")
        .select("role")
        .eq("id", session.user.id)
        .maybeSingle();

      if (profile && (profile.role === "admin" || profile.role === "superadmin")) {
        window.location.href = "/admin";
      }
    }

    checkCurrentSession();

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();

      const email = emailInput?.value?.trim() || "";
      const password = passwordInput?.value || "";

      setMessage("");

      if (loginBtn) {
        loginBtn.disabled = true;
        loginBtn.textContent = "Sedang login...";
      }

      const { data, error } = await supabase.auth.signInWithPassword({
        email,
        password,
      });

      if (error) {
        setMessage("Login gagal: " + error.message);
        if (loginBtn) {
          loginBtn.disabled = false;
          loginBtn.textContent = "Login";
        }
        return;
      }

      const userId = data?.user?.id;
      if (!userId) {
        setMessage("Session login tidak valid.");
        if (loginBtn) {
          loginBtn.disabled = false;
          loginBtn.textContent = "Login";
        }
        return;
      }

      const { data: profile, error: profileError } = await supabase
        .from("profiles")
        .select("role")
        .eq("id", userId)
        .maybeSingle();

      if (profileError || !profile) {
        setMessage("Profil user tidak ditemukan.");
        if (loginBtn) {
          loginBtn.disabled = false;
          loginBtn.textContent = "Login";
        }
        return;
      }

      if (profile.role !== "admin" && profile.role !== "superadmin") {
        setMessage("Akses ditolak. Akun ini bukan admin.");
        if (loginBtn) {
          loginBtn.disabled = false;
          loginBtn.textContent = "Login";
        }
        return;
      }

      setMessage("Login berhasil. Mengarahkan...", "success");
      window.location.href = "/admin";
    });
  </script>
</BaseLayout>