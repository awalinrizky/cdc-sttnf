---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="403 | Akses Ditolak">
  <section class="forbidden">
    <div class="box">
      <h1>403</h1>
      <h2>Akses Ditolak</h2>
      <p>Anda tidak memiliki izin untuk membuka halaman ini.</p>
      <a href="/" class="btn btn-primary">Kembali ke Beranda</a>
    </div>
  </section>

  <style>
    .forbidden {
      min-height: calc(100vh - 180px);
      display: grid;
      place-items: center;
      padding: 40px 16px;
    }

    .box {
      text-align: center;
      max-width: 520px;
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 18px;
      padding: 36px 24px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
    }

    .box h1 {
      font-size: 64px;
      line-height: 1;
      margin-bottom: 8px;
    }

    .box h2 {
      font-size: 28px;
      margin-bottom: 12px;
    }

    .box p {
      color: #64748b;
      margin-bottom: 24px;
      line-height: 1.8;
    }
  </style>
</BaseLayout>