---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Workshop & Event | CDC STT-NF">
  <section class="hero-event">
    <div class="container hero-wrap">
      <span class="eyebrow-glow">Workshop & Seminar</span>
      <h1>Tingkatkan Skill bareng Expert di CDC STT-NF</h1>
      <p>
        Persiapkan karier masa depanmu dengan mengikuti berbagai pelatihan intensif, 
        seminar industri, dan workshop praktis yang dirancang khusus untuk mahasiswa.
      </p>
    </div>
  </section>

  <section class="event-feed-section">
    <div class="container">
      <div class="section-intro">
        <h2 class="section-title">Agenda Terdekat</h2>
        <p class="section-subtitle">
          Jangan lewatkan kesempatan emas untuk memperluas jaringan dan kompetensi profesionalmu.
        </p>
      </div>

      <div id="eventList" class="event-grid-pro">
        <div class="loader-container">
            <div class="spinner"></div>
            <p>Menghubungkan ke jadwal event...</p>
        </div>
      </div>
    </div>
  </section>

  <style is:global>
    :root {
      --primary: #4f46e5;
      --primary-dark: #4338ca;
      --slate-900: #0f172a;
      --slate-700: #334155;
      --slate-500: #64748b;
      --emerald-600: #059669;
    }

    /* HERO STYLING */
    .hero-event {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      color: white;
      padding: 100px 0 80px;
      text-align: center;
    }

    .hero-wrap {
      width: min(100% - 32px, 850px);
      margin-inline: auto;
    }

    .eyebrow-glow {
      display: inline-flex;
      padding: 8px 16px;
      border-radius: 99px;
      background: rgba(79, 70, 229, 0.15);
      color: #818cf8;
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      border: 1px solid rgba(129, 140, 248, 0.3);
      margin-bottom: 24px;
    }

    .hero-wrap h1 {
      font-size: clamp(32px, 5vw, 52px);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.04em;
      margin-bottom: 20px;
    }

    .hero-wrap p {
      color: #94a3b8;
      font-size: 18px;
      line-height: 1.7;
    }

    /* FEED SECTION */
    .event-feed-section {
      padding: 80px 0 120px;
      background: #f8fafc;
      min-height: 500px;
    }

    .section-intro { margin-bottom: 50px; text-align: left; }
    .section-title { font-size: 32px; font-weight: 800; color: var(--slate-900); letter-spacing: -0.02em; }
    .section-subtitle { color: var(--slate-500); font-size: 16px; margin-top: 8px; }

    /* GRID & CARDS */
    .event-grid-pro {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(480px, 1fr));
      gap: 30px;
    }

    .event-card-pro {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 24px;
      padding: 32px;
      display: flex;
      flex-direction: column;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
    }

    .event-card-pro:hover {
      transform: translateY(-8px);
      border-color: var(--primary);
      box-shadow: 0 20px 25px -5px rgba(0,0,0,0.05);
    }

    .event-status-tag {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        padding: 6px 12px;
        border-radius: 8px;
        background: #ecfdf5;
        color: var(--emerald-600);
        font-size: 12px;
        font-weight: 800;
        margin-bottom: 20px;
        text-transform: uppercase;
    }

    .event-card-pro h3 {
      font-size: 24px;
      font-weight: 800;
      color: var(--slate-900);
      line-height: 1.3;
      margin-bottom: 12px;
    }

    .event-info-row {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      margin-bottom: 20px;
      color: var(--slate-500);
      font-size: 14px;
      font-weight: 500;
    }

    .info-item { display: flex; align-items: center; gap: 6px; }

    .event-description {
      color: var(--slate-700);
      font-size: 15px;
      line-height: 1.7;
      margin-bottom: 30px;
      flex: 1;
    }

    /* BUTTONS */
    .btn-pro {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 14px 24px;
      border-radius: 12px;
      font-weight: 700;
      font-size: 15px;
      text-decoration: none;
      transition: 0.2s;
    }

    .btn-indigo { background: var(--primary); color: white; box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2); }
    .btn-indigo:hover { background: var(--primary-dark); transform: translateY(-2px); }

    .btn-disabled { background: #f1f5f9; color: #94a3b8; border: 1px solid #e2e8f0; cursor: not-allowed; }

    /* LOADING SPINNER */
    .loader-container { grid-column: 1 / -1; text-align: center; padding: 100px 0; color: var(--slate-500); }
    .spinner { width: 40px; height: 40px; border: 4px solid #e2e8f0; border-top-color: var(--primary); border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 16px; }
    @keyframes spin { to { transform: rotate(360deg); } }

    @media (max-width: 768px) {
      .event-grid-pro { grid-template-columns: 1fr; }
      .event-card-pro { padding: 24px; }
    }
  </style>

  <script>
    // @ts-nocheck
    import { supabase } from "../../lib/supabase.js";
    import { requireMahasiswa } from "../../lib/adminGuard.js";

    const eventList = document.getElementById("eventList");

    async function loadEvents() {
      const { data, error } = await supabase
        .from("events")
        .select("*")
        .eq("is_active", true)
        .order("date", { ascending: true });

      if (error) {
        eventList.innerHTML = `<p class="loader-container">Gagal memuat jadwal event.</p>`;
        return;
      }

      if (!data || !data.length) {
        eventList.innerHTML = `<p class="loader-container">Saat ini belum ada event mendatang.</p>`;
        return;
      }

      eventList.innerHTML = data.map(event => {
        const eventDate = event.date 
          ? new Date(event.date).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })
          : "TBA";
        
        const eventTime = event.date 
          ? new Date(event.date).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' })
          : "";

        return `
          <article class="event-card-pro">
            <div class="event-status-tag">Coming Soon</div>
            <h3>${event.title}</h3>
            
            <div class="event-info-row">
              <div class="info-item">
                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                ${eventDate} ${eventTime ? '• ' + eventTime : ''}
              </div>
              <div class="info-item">
                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                ${event.location || 'Info Menyusul'}
              </div>
            </div>

            <p class="event-description">
                ${event.description || 'Segera hadir sesi workshop menarik untuk persiapan karier profesionalmu.'}
            </p>

            <div class="event-actions">
              ${event.register_url 
                ? `<a href="${event.register_url}" target="_blank" class="btn-pro btn-indigo">Daftar Sekarang</a>`
                : `<span class="btn-pro btn-disabled">Pendaftaran Belum Dibuka</span>`
              }
            </div>
          </article>
        `;
      }).join("");
    }

    // Jalankan Satpam Mahasiswa
    requireMahasiswa().then(session => {
      if (session) loadEvents();
    });
  </script>
</BaseLayout>