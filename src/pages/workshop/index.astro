---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Workshop | CDC STT-NF">
  <section class="hero-section">
    <div class="container hero-wrap">
      <span class="eyebrow">Pengembangan Skill</span>
      <h1>Workshop & Seminar</h1>
      <p>
        Ikuti workshop dan seminar yang membantu mahasiswa serta alumni
        mempersiapkan diri menghadapi dunia kerja profesional.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2 class="section-title">Event Terbaru</h2>
        <p class="section-subtitle">
          Kegiatan CDC STT-NF untuk mendukung pengembangan kompetensi dan kesiapan karier.
        </p>
      </div>

      <div id="eventList" class="event-grid">
        <p class="state-message">Memuat workshop dan seminar...</p>
      </div>
    </div>
  </section>

  <style>
    .hero-section {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      color: white;
      padding: 88px 0 78px;
    }

    .hero-wrap {
      max-width: 760px;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.1);
      color: #dcfce7;
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 18px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .hero-wrap h1 {
      font-size: clamp(34px, 5vw, 56px);
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin-bottom: 16px;
    }

    .hero-wrap p {
      color: #cbd5e1;
      line-height: 1.9;
      max-width: 680px;
      font-size: 17px;
    }

    .section-head {
      margin-bottom: 28px;
    }

    .event-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 22px;
    }

    .event-card {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 20px;
      padding: 24px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .event-date {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      padding: 8px 12px;
      border-radius: 999px;
      background: #dcfce7;
      color: #166534;
      font-size: 12px;
      font-weight: 700;
    }

    .event-card h3 {
      font-size: 22px;
      line-height: 1.3;
      letter-spacing: -0.02em;
    }

    .event-meta {
      color: #64748b;
      font-size: 14px;
      line-height: 1.8;
    }

    .event-desc {
      color: #475569;
      line-height: 1.8;
      font-size: 15px;
    }

    .event-actions {
      margin-top: auto;
      padding-top: 8px;
    }

    .state-message {
      color: #64748b;
      font-size: 16px;
    }

    @media (max-width: 900px) {
      .event-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    // @ts-nocheck
    import { supabase } from "../../lib/supabase.js";

    const eventList = document.getElementById("eventList");

    function formatDate(dateValue) {
      if (!dateValue) return "Tanggal belum ditentukan";
      return new Date(dateValue).toLocaleDateString("id-ID", {
        day: "numeric",
        month: "long",
        year: "numeric",
      });
    }

    async function loadEvents() {
      const { data, error } = await supabase
        .from("events")
        .select("*")
        .eq("is_active", true)
        .order("date", { ascending: true });

      if (error) {
        if (eventList) {
          eventList.innerHTML = `<p class="state-message">Gagal memuat event.</p>`;
        }
        return;
      }

      if (!data || !data.length) {
        if (eventList) {
          eventList.innerHTML = `<p class="state-message">Belum ada workshop atau seminar.</p>`;
        }
        return;
      }

      if (eventList) {
        eventList.innerHTML = data
          .map(
            (event) => `
              <article class="event-card">
                <span class="event-date">${formatDate(event.date)}</span>
                <h3>${event.title || "-"}</h3>
                <div class="event-meta">
                  <div><strong>Lokasi:</strong> ${event.location || "-"}</div>
                </div>
                <p class="event-desc">${event.description || "Belum ada deskripsi event."}</p>
                <div class="event-actions">
                  ${
                    event.register_url
                      ? `<a href="${event.register_url}" class="btn btn-primary" target="_blank" rel="noreferrer">Daftar Sekarang</a>`
                      : `<span class="btn btn-light" style="pointer-events:none; opacity:.75;">Pendaftaran Belum Tersedia</span>`
                  }
                </div>
              </article>
            `
          )
          .join("");
      }
    }

    loadEvents();
  </script>
</BaseLayout>