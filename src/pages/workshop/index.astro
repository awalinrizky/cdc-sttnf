---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Workshop | CDC STT-NF">
  <section class="hero-section">
    <div class="container hero-wrap">
      <span class="eyebrow">Workshop & Seminar</span>
      <h1>Belajar skill yang dibutuhkan industri, bareng CDC STT-NF.</h1>
      <p>
        Ikuti workshop, seminar, dan sesi pengembangan karier yang dirancang untuk
        membantu mahasiswa serta alumni lebih siap menghadapi dunia kerja.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2 class="section-title">Event Terbaru</h2>
        <p class="section-subtitle">
          Kegiatan CDC STT-NF untuk mendukung pengembangan kompetensi dan kesiapan karier.
        </p>
      </div>

      <div id="eventList" class="event-grid">
        <p class="state-message">Memuat workshop dan seminar...</p>
      </div>
    </div>
  </section>

  <style is:global>
    .hero-section {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      color: white;
      padding: 88px 0 76px;
    }

    .hero-wrap {
      width: min(100% - 32px, 1120px);
      margin-inline: auto;
      max-width: 780px;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.1);
      color: #dcfce7;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      margin-bottom: 18px;
    }

    .hero-wrap h1 {
      font-size: clamp(34px, 5vw, 58px);
      line-height: 1.04;
      letter-spacing: -0.03em;
      margin-bottom: 16px;
      max-width: 820px;
    }

    .hero-wrap p {
      color: #cbd5e1;
      font-size: 17px;
      line-height: 1.9;
      max-width: 700px;
    }

    .section {
      padding: 72px 0;
    }

    .section .container {
      width: min(100% - 32px, 1120px);
      margin-inline: auto;
    }

    .section-head {
      margin-bottom: 28px;
    }

    .section-title {
      font-size: clamp(28px, 4vw, 40px);
      margin-bottom: 12px;
      letter-spacing: -0.03em;
      color: #0f172a;
    }

    .section-subtitle {
      color: #64748b;
      line-height: 1.8;
      max-width: 720px;
      font-size: 16px;
    }

    .event-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 22px;
    }

    .event-card {
      background: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 22px;
      padding: 24px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
      display: flex;
      flex-direction: column;
      gap: 14px;
      min-height: 280px;
      transition: 0.2s ease;
    }

    .event-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 18px 34px rgba(15, 23, 42, 0.08);
    }

    .event-date {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      padding: 8px 12px;
      border-radius: 999px;
      background: #dcfce7;
      color: #166534;
      font-size: 12px;
      font-weight: 700;
    }

    .event-card h3 {
      font-size: 24px;
      line-height: 1.25;
      letter-spacing: -0.02em;
      color: #0f172a;
    }

    .event-meta {
      color: #475569;
      font-size: 14px;
      line-height: 1.8;
    }

    .event-meta strong {
      color: #0f172a;
    }

    .event-desc {
      color: #475569;
      font-size: 15px;
      line-height: 1.85;
    }

    .event-actions {
      margin-top: auto;
      padding-top: 8px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 12px;
      padding: 12px 18px;
      font-weight: 700;
      text-decoration: none;
    }

    .btn-primary {
      background: #22c55e;
      color: white;
    }

    .btn-primary:hover {
      background: #16a34a;
    }

    .btn-light {
      background: #f8fafc;
      color: #0f172a;
      border: 1px solid #e2e8f0;
    }

    .state-message {
      color: #64748b;
      font-size: 16px;
    }

    @media (max-width: 900px) {
      .event-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    // @ts-nocheck
    import { supabase } from "../../lib/supabase.js";

    const eventList = document.getElementById("eventList");

    function formatDate(dateValue) {
      if (!dateValue) return "Tanggal belum ditentukan";
      return new Date(dateValue).toLocaleDateString("id-ID", {
        day: "numeric",
        month: "long",
        year: "numeric",
      });
    }

    async function loadEvents() {
      const { data, error } = await supabase
        .from("events")
        .select("*")
        .eq("is_active", true)
        .order("date", { ascending: true });

      if (error) {
        if (eventList) {
          eventList.innerHTML = `<p class="state-message">Gagal memuat event.</p>`;
        }
        return;
      }

      if (!data || !data.length) {
        if (eventList) {
          eventList.innerHTML = `<p class="state-message">Belum ada workshop atau seminar.</p>`;
        }
        return;
      }

      eventList.innerHTML = data
        .map(
          (event) => `
            <article class="event-card">
              <span class="event-date">${formatDate(event.date)}</span>
              <h3>${event.title || "-"}</h3>
              <div class="event-meta">
                <div><strong>Lokasi:</strong> ${event.location || "-"}</div>
              </div>
              <p class="event-desc">${event.description || "Belum ada deskripsi event."}</p>
              <div class="event-actions">
                ${
                  event.register_url
                    ? `<a href="${event.register_url}" class="btn btn-primary" target="_blank" rel="noreferrer">Daftar Sekarang</a>`
                    : `<span class="btn btn-light" style="pointer-events:none; opacity:.75;">Pendaftaran Belum Tersedia</span>`
                }
              </div>
            </article>
          `
        )
        .join("");
    }

    loadEvents();
  </script>
</BaseLayout>