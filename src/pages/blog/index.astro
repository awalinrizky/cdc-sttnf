---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="CDC STT-NF | Beranda">
  <section class="page-hero">
    <div class="container page-hero__wrap">
      <span class="page-eyebrow">Career Development Center</span>
      <h1>Mempersiapkan Mahasiswa & Alumni Menuju Dunia Kerja Profesional</h1>
      <p>
        CDC STT-NF membantu mahasiswa dan alumni menemukan lowongan kerja,
        magang, workshop, seminar, dan peluang pengembangan karier yang relevan.
      </p>

      <div class="hero-actions">
        <a href="/lowongan" class="btn btn-primary">Lihat Lowongan</a>
        <a href="/roadmap" class="btn btn-outline">Lihat Roadmap</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2 class="section-title">Tentang CDC STT-NF</h2>
        <p class="section-subtitle">
          CDC STT-NF menjadi ruang penghubung antara mahasiswa, alumni, dan dunia kerja
          melalui informasi lowongan, pengembangan skill, workshop, seminar, dan roadmap karier.
        </p>
      </div>

      <div class="feature-grid">
        <article class="feature-card">
          <span class="tag">Jobs</span>
          <h3>Lowongan Terkurasi</h3>
          <p>Temukan peluang kerja dan magang yang lebih relevan untuk mahasiswa dan alumni.</p>
        </article>

        <article class="feature-card">
          <span class="tag">Growth</span>
          <h3>Career Growth</h3>
          <p>Dukung perjalanan karier melalui workshop, seminar, insight, dan peluang aktual.</p>
        </article>

        <article class="feature-card">
          <span class="tag">Network</span>
          <h3>Siap Terhubung</h3>
          <p>Bangun jembatan antara kampus, alumni, dan dunia kerja profesional.</p>
        </article>
      </div>
    </div>
  </section>

  <style>
    .hero-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin-top: 28px;
    }

    .feature-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
    }

    .feature-card {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 22px;
      padding: 24px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
      display: grid;
      gap: 14px;
      transition: 0.2s ease;
    }

    .feature-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 18px 34px rgba(15, 23, 42, 0.08);
    }

    .feature-card h3 {
      font-size: 24px;
      line-height: 1.3;
      letter-spacing: -0.02em;
    }

    .feature-card p {
      color: #64748b;
      line-height: 1.85;
      font-size: 15px;
    }

    @media (max-width: 900px) {
      .feature-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
  <script>
    // @ts-nocheck
    import { supabase } from "../../lib/supabase.js";
    import { requireMahasiswa } from "../../lib/adminGuard.js";

    // Asumsi lo punya <div id="postList"></div> di HTML blog lo
    const postList = document.getElementById("postList");

    async function loadPosts() {
      const { data, error } = await supabase
        .from("posts")
        .select("*")
        .eq("published", true)
        .order("created_at", { ascending: false });

      if (error) {
        if (postList) postList.innerHTML = `<p>Gagal memuat blog.</p>`;
        return;
      }

      if (!data || !data.length) {
        if (postList) postList.innerHTML = `<p>Belum ada artikel.</p>`;
        return;
      }

      // Sesuaikan desain HTML ini dengan UI blog lo
      if (postList) {
        postList.innerHTML = data.map(post => `
          <article class="card p-4 mb-4">
            <h3>${post.title}</h3>
            <p>${(post.content || "").slice(0, 150)}...</p>
            <a href="/blog/${post.slug}">Baca selengkapnya</a>
          </article>
        `).join("");
      }
    }

    requireMahasiswa().then((session) => {
      if (session) {
        loadPosts();
      }
    });
  </script>
</BaseLayout>