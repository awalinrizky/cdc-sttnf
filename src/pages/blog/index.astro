---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="CDC STT-NF | Beranda">
  <section class="page-hero">
    <div class="container page-hero__wrap">
      <span class="page-eyebrow">Career Development Center</span>
      <h1>Mempersiapkan Mahasiswa & Alumni Menuju Dunia Kerja Profesional</h1>
      <p>
        CDC STT-NF membantu mahasiswa dan alumni menemukan lowongan kerja,
        magang, workshop, seminar, dan peluang pengembangan karier yang relevan.
      </p>

      <div class="hero-actions">
        <a href="/lowongan" class="btn btn-primary">Lihat Lowongan</a>
        <a href="/roadmap" class="btn btn-outline">Lihat Roadmap</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2 class="section-title">Tentang CDC STT-NF</h2>
        <p class="section-subtitle">
          CDC STT-NF menjadi ruang penghubung antara mahasiswa, alumni, dan dunia kerja
          melalui informasi lowongan, pengembangan skill, workshop, seminar, dan roadmap karier.
        </p>
      </div>

      <div id="blogGrid" class="blog-grid">
        <div class="loading-status">Menarik artikel terbaru...</div>
      </div>

    </div>
  </section>

  <style is:global>
    :root {
      --primary: #4f46e5;
      --slate-900: #0f172a;
      --slate-600: #475569;
      --slate-200: #e2e8f0;
      --white: #ffffff;
    }

    .blog-section {
      padding: 80px 0 120px;
      background-color: #f8fafc; /* Abu-abu sangat muda biar teks hitamnya kontras */
      min-height: 100vh;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .container {
      width: min(100% - 32px, 1200px);
      margin-inline: auto;
    }

    /* HEADER */
    .blog-header {
      text-align: center;
      margin-bottom: 60px;
      max-width: 800px;
      margin-inline: auto;
    }

    .eyebrow {
      color: var(--primary);
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-size: 13px;
      margin-bottom: 16px;
      display: block;
    }

    .blog-header h1 {
      font-size: clamp(32px, 5vw, 48px);
      font-weight: 800;
      color: var(--slate-900);
      letter-spacing: -0.04em;
      margin-bottom: 16px;
    }

    .blog-header p {
      font-size: 18px;
      color: var(--slate-600);
      line-height: 1.6;
    }

    /* GRID */
    .blog-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
      gap: 32px;
    }

    /* CARD DESIGN (MAHAL & BERSIH) */
    .blog-card {
      background: var(--white);
      border: 1px solid var(--slate-200);
      border-radius: 24px;
      padding: 40px;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
    }

    .blog-card:hover {
      transform: translateY(-8px);
      border-color: var(--primary);
      box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
    }

    .card-date {
      font-size: 13px;
      font-weight: 600;
      color: #94a3b8;
      margin-bottom: 12px;
    }

    .blog-card h2 {
      font-size: 24px;
      font-weight: 800;
      color: var(--slate-900);
      line-height: 1.3;
      margin-bottom: 16px;
      transition: color 0.2s;
    }

    .blog-card:hover h2 {
      color: var(--primary);
    }

    .blog-card p {
      font-size: 16px;
      color: var(--slate-600);
      line-height: 1.7;
      margin-bottom: 24px;
      flex: 1;
    }

    .read-more-btn {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--primary);
      font-weight: 700;
      font-size: 15px;
    }

    .loading-status {
      grid-column: 1 / -1;
      text-align: center;
      padding: 100px 0;
      color: #94a3b8;
      font-weight: 600;
    }

    @media (max-width: 640px) {
      .blog-grid { grid-template-columns: 1fr; }
      .blog-card { padding: 32px; }
    }
  </style>

  <script>
    // @ts-nocheck
    import { supabase } from "../../lib/supabase.js";

    async function loadBlogPro() {
      const container = document.getElementById("blogGrid");

      // 1. Ambil data asli dari Superadmin
      const { data, error } = await supabase
        .from("posts")
        .select("*")
        .eq("published", true)
        .order("created_at", { ascending: false });

      if (error) {
        container.innerHTML = `<p class="loading-status">Gagal memuat data: ${error.message}</p>`;
        return;
      }

      if (!data || data.length === 0) {
        container.innerHTML = `<p class="loading-status">Belum ada artikel yang dipublikasikan.</p>`;
        return;
      }

      // 2. Render dengan desain Profesional
      container.innerHTML = ""; // Bersihkan data statis/loading

      data.forEach((post) => {
        const date = new Date(post.created_at).toLocaleDateString('id-ID', {
          day: 'numeric',
          month: 'long',
          year: 'numeric'
        });

        const ringkasan = post.content 
          ? post.content.substring(0, 140) + "..." 
          : "Klik untuk membaca selengkapnya.";

        // Masukkan template ke Grid
        container.innerHTML += `
          <a href="/blog/${post.slug}" class="blog-card">
            <span class="card-date">${date}</span>
            <h2>${post.title}</h2>
            <p>${ringkasan}</p>
            <div class="read-more-btn">
              Baca Artikel
              <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </a>
        `;
      });
    }

    loadBlogPro();
  </script>
</BaseLayout>