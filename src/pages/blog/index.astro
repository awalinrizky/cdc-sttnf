---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Blog | CDC STT-NF">
  <section class="hero-section">
    <div class="container hero-wrap">
      <span class="eyebrow">Wawasan Karier</span>
      <h1>Artikel Karier</h1>
      <p>
        Temukan insight, tips, dan panduan karier untuk membantu mahasiswa dan alumni
        lebih siap memasuki dunia profesional.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2 class="section-title">Artikel Terbaru</h2>
        <p class="section-subtitle">
          Bahan bacaan ringan dan praktis untuk mendukung pengembangan karier.
        </p>
      </div>

      <div id="postList" class="post-grid">
        <p class="state-message">Memuat artikel...</p>
      </div>
    </div>
  </section>

  <style>
    .hero-section {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      color: white;
      padding: 88px 0 78px;
    }

    .hero-wrap {
      max-width: 760px;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.1);
      color: #dcfce7;
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 18px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .hero-wrap h1 {
      font-size: clamp(34px, 5vw, 56px);
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin-bottom: 16px;
    }

    .hero-wrap p {
      color: #cbd5e1;
      line-height: 1.9;
      max-width: 680px;
      font-size: 17px;
    }

    .section-head {
      margin-bottom: 28px;
    }

    .post-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 22px;
    }

    .post-card {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 20px;
      padding: 24px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05);
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .post-tag {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      padding: 8px 12px;
      border-radius: 999px;
      background: #f1f5f9;
      color: #0f172a;
      font-size: 12px;
      font-weight: 700;
    }

    .post-card h3 {
      font-size: 22px;
      line-height: 1.3;
      letter-spacing: -0.02em;
    }

    .post-card p {
      color: #475569;
      line-height: 1.8;
      font-size: 15px;
    }

    .post-link {
      margin-top: auto;
      font-weight: 700;
      color: #0f172a;
    }

    .post-link:hover {
      color: #16a34a;
    }

    .state-message {
      color: #64748b;
      font-size: 16px;
    }

    @media (max-width: 900px) {
      .post-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    // @ts-nocheck
    import { supabase } from "../../lib/supabase.js";

    const postList = document.getElementById("postList");

    async function loadPosts() {
      const { data, error } = await supabase
        .from("posts")
        .select("*")
        .eq("published", true)
        .order("created_at", { ascending: false });

      if (error) {
        if (postList) {
          postList.innerHTML = `<p class="state-message">Gagal memuat artikel.</p>`;
        }
        return;
      }

      if (!data || !data.length) {
        if (postList) {
          postList.innerHTML = `<p class="state-message">Belum ada artikel tersedia.</p>`;
        }
        return;
      }

      if (postList) {
        postList.innerHTML = data
          .map(
            (post) => `
              <article class="post-card">
                <span class="post-tag">Career Insight</span>
                <h3>${post.title || "-"}</h3>
                <p>${(post.content || "Belum ada ringkasan artikel.").slice(0, 180)}${(post.content || "").length > 180 ? "..." : ""}</p>
                <a class="post-link" href="/blog">Baca selengkapnya →</a>
              </article>
            `
          )
          .join("");
      }
    }

    loadPosts();
  </script>
</BaseLayout>