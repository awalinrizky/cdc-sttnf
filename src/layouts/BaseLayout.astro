---
const { title = "CDC STT-NF" } = Astro.props;
const year = new Date().getFullYear();
const pathname = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta
      name="description"
      content="Career Development Center STT-NF untuk lowongan kerja, workshop, seminar, blog, dan roadmap karier."
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Career Development Center STT-NF" />

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      :root {
        --bg: #f8fafc;
        --surface: #ffffff;
        --surface-soft: #f1f5f9;
        --text: #0f172a;
        --muted: #64748b;
        --primary: #0f172a;
        --primary-soft: #1e293b;
        --accent: #22c55e;
        --accent-dark: #16a34a;
        --accent-soft: #dcfce7;
        --border: #e2e8f0;
        --danger: #ef4444;
        --danger-dark: #dc2626;
        --shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
        --shadow-hover: 0 18px 36px rgba(15, 23, 42, 0.1);
        --container: 1120px;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: "Inter", sans-serif;
        background: var(--bg);
        color: var(--text);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .container {
        width: min(100% - 32px, var(--container));
        margin-inline: auto;
      }

      .page-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        color: white;
        padding: 88px 0 76px;
      }

      .page-hero__wrap {
        max-width: 820px;
      }

      .page-eyebrow {
        display: inline-flex;
        align-items: center;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.1);
        color: #dcfce7;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        margin-bottom: 18px;
      }

      .page-hero h1 {
        font-size: clamp(34px, 5vw, 58px);
        line-height: 1.04;
        letter-spacing: -0.03em;
        margin-bottom: 16px;
      }

      .page-hero p {
        color: #cbd5e1;
        font-size: 17px;
        line-height: 1.9;
        max-width: 720px;
      }

      .section {
        padding: 72px 0;
      }

      .section-head {
        margin-bottom: 28px;
      }

      .section-title {
        font-size: clamp(28px, 4vw, 40px);
        margin-bottom: 12px;
        letter-spacing: -0.03em;
        color: var(--text);
      }

      .section-subtitle {
        color: var(--muted);
        line-height: 1.8;
        font-size: 16px;
        max-width: 760px;
      }

      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 22px;
        box-shadow: var(--shadow);
      }

      .card-soft {
        background: var(--surface-soft);
        border: 1px solid var(--border);
        border-radius: 18px;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        padding: 8px 12px;
        border-radius: 999px;
        background: var(--accent-soft);
        color: #166534;
        font-size: 12px;
        font-weight: 700;
      }

      .tag {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        padding: 8px 12px;
        border-radius: 999px;
        background: var(--surface-soft);
        color: var(--text);
        font-size: 12px;
        font-weight: 700;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border: none;
        border-radius: 14px;
        padding: 12px 18px;
        cursor: pointer;
        font-weight: 700;
        transition: 0.2s ease;
        text-decoration: none;
      }

      .btn:hover {
        transform: translateY(-1px);
      }

      .btn-primary {
        background: var(--accent);
        color: white;
      }

      .btn-primary:hover {
        background: var(--accent-dark);
      }

      .btn-outline {
        background: white;
        color: var(--text);
        border: 1px solid var(--border);
      }

      .btn-outline:hover {
        background: #f8fafc;
      }

      .btn-light {
        background: white;
        color: var(--primary);
        border: 1px solid var(--border);
      }

      .btn-light:hover {
        background: #f8fafc;
      }

      .btn-danger {
        background: var(--danger);
        color: white;
      }

      .btn-danger:hover {
        background: var(--danger-dark);
      }

      nav {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(15, 23, 42, 0.94);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }

      .nav-wrap {
        min-height: 76px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
      }

      .logo {
        color: white;
        font-size: 28px;
        font-weight: 800;
        letter-spacing: -0.03em;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: center;
      }

      .nav-links a {
        color: #cbd5e1;
        font-size: 14px;
        font-weight: 500;
        padding: 10px 14px;
        border-radius: 999px;
        transition: 0.2s ease;
      }

      .nav-links a:hover {
        color: white;
        background: rgba(255, 255, 255, 0.08);
      }

      .nav-links a.active {
        color: white;
        background: rgba(255, 255, 255, 0.12);
      }

      .nav-actions {
        display: flex;
        align-items: center;
      }

      .nav-admin-btn {
        min-width: 90px;
        border-radius: 10px;
        font-weight: 500;
      }

      main {
        min-height: 78vh;
      }

      footer {
        margin-top: 64px;
        background: var(--primary);
        color: #cbd5e1;
        padding: 36px 0;
        text-align: center;
        font-size: 14px;
        line-height: 1.8;
      }

      @media (max-width: 960px) {
        .nav-wrap {
          flex-direction: column;
          align-items: stretch;
          padding: 16px 0;
        }

        .logo {
          text-align: center;
        }

        .nav-links {
          justify-content: center;
        }

        .nav-actions {
          justify-content: center;
        }
      }
    </style>
  </head>

  <body>
    <nav>
      <div class="container nav-wrap">
        <a href="/" class="logo">CDC STT-NF</a>

        <div class="nav-links">
          <a href="/" class={pathname === "/" ? "active" : ""}>Home</a>
          <a href="/lowongan" class={pathname.startsWith("/lowongan") ? "active" : ""}>Jobs</a>
          <a href="/workshop" class={pathname.startsWith("/workshop") ? "active" : ""}>Workshops</a>
          <a href="/roadmap" class={pathname.startsWith("/roadmap") ? "active" : ""}>Roadmap</a>
          <a href="/blog" class={pathname.startsWith("/blog") ? "active" : ""}>Blog</a>
        </div>

        <div class="nav-actions">
          <a href="/login" class="btn btn-light nav-admin-btn">Admin</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container">
        Career Development Center (CDC) <br />
        Sekolah Tinggi Teknologi Terpadu Nurul Fikri <br />
        © {year} All rights reserved
      </div>
    </footer>
  </body>
</html>