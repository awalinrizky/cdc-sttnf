{
	"version": 3,
	"routes": [
		{
			"src": "^/jobs$",
			"headers": {
				"Location": "/lowongan"
			},
			"status": 301
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/403/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/event/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/job/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog/?$",
			"dest": "_render"
		},
		{
			"src": "^/jobs/?$",
			"dest": "_render"
		},
		{
			"src": "^/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/lowongan/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/lowongan/?$",
			"dest": "_render"
		},
		{
			"src": "^/lowongan/?$",
			"dest": "_render"
		},
		{
			"src": "^/roadmap/?$",
			"dest": "_render"
		},
		{
			"src": "^/workshop/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	]
}